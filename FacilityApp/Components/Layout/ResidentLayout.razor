@inherits LayoutComponentBase
@inject TenantContext TenantCtx
@inject ITenantService TenantService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<div class="resident-root">
    <nav class="resident-navbar navbar navbar-expand-lg">
        <div class="container-fluid px-4">
            <a class="navbar-brand d-flex align-items-center gap-2" href="@($"{TenantCtx.RouteBase}/resident")">
                <div class="resident-brand-icon"><i class="bi bi-buildings"></i></div>
                <span class="fw-bold">@(TenantCtx.IsResolved ? TenantCtx.TenantName : "FacilityApp")</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#residentNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="residentNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/resident")" Match="NavLinkMatch.All">
                            <i class="bi bi-speedometer2 me-1"></i> Dashboard
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/resident/visits")">
                            <i class="bi bi-calendar-check me-1"></i> My Visits
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/resident/preregister")">
                            <i class="bi bi-person-plus me-1"></i> Pre-register
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/resident/maintenance")">
                            <i class="bi bi-tools me-1"></i> Maintenance
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/resident/documents")">
                            <i class="bi bi-folder2-open me-1"></i> Documents
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/resident/profile")">
                            <i class="bi bi-person-circle me-1"></i> My Profile
                        </NavLink>
                    </li>
                </ul>

                <div class="d-flex align-items-center gap-3">
                    @if (_isAuthenticated)
                    {
                        <span class="resident-user-name small">
                            <i class="bi bi-person-circle me-1"></i>@_userName
                        </span>
                        <form method="post" action="@($"{TenantCtx.RouteBase}/api/resident/logout")">
                            <AntiForgeryToken />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-box-arrow-right me-1"></i>Sign Out
                            </button>
                        </form>
                    }
                    else
                    {
                        <a href="@($"{TenantCtx.RouteBase}/resident/login")" class="btn btn-sm btn-primary">Sign In</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="resident-content">
        <div class="container py-4">
            <CascadingAuthenticationState>
                @Body
            </CascadingAuthenticationState>
        </div>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private bool _isAuthenticated;
    private string _userName = "";

    private string CurrentSlug =>
        !string.IsNullOrEmpty(TenantCtx.TenantSlug)
            ? TenantCtx.TenantSlug
            : new Uri(Nav.Uri).AbsolutePath.Trim('/').Split('/').FirstOrDefault() ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var slug = new Uri(Nav.Uri).AbsolutePath.Trim('/').Split('/').FirstOrDefault();
            if (!string.IsNullOrEmpty(slug))
            {
                var tenant = await TenantService.ResolveBySlugAsync(slug);
                if (tenant is not null)
                {
                    TenantCtx.TenantId   = tenant.Id;
                    TenantCtx.TenantSlug = tenant.Slug;
                    TenantCtx.TenantName = tenant.Name;
                    TenantCtx.IsResolved = true;
                }
            }
        }

        var auth = await AuthState.GetAuthenticationStateAsync();
        _isAuthenticated = auth.User.Identity?.IsAuthenticated ?? false;
        _userName = auth.User.Identity?.Name ?? "";
    }
}
