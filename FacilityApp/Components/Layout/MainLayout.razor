@inherits LayoutComponentBase
@inject TenantContext TenantCtx
@inject GateContext GateCtx
@inject ITenantService TenantService
@inject IEntranceService EntranceSvc
@inject AuthenticationStateProvider AuthState
@inject UserManager<ApplicationUser> UserMgr
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <div class="breadcrumb-area">
                @if (TenantCtx.IsResolved)
                {
                    <small class="text-muted">
                        <i class="bi bi-buildings me-1"></i>@TenantCtx.TenantName
                    </small>
                }
            </div>
            <div class="d-flex align-items-center gap-3">
                <small class="text-muted d-none d-sm-block">@DateTime.Now.ToString("ddd, MMM d yyyy")</small>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleThemeAsync"
                        title="Toggle dark/light mode">
                    <i class="bi @(_isDark ? "bi-sun" : "bi-moon")"></i>
                </button>
            </div>
        </div>

        <article class="content px-4">
            <ErrorBoundary>
                <ChildContent>@Body</ChildContent>
                <ErrorContent>
                    <div class="alert alert-danger d-flex align-items-start gap-3 m-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill fs-4 flex-shrink-0 mt-1"></i>
                        <div>
                            <h6 class="mb-1">Something went wrong on this page</h6>
                            <p class="mb-2 small">An unexpected error occurred. Your other work is not affected.</p>
                            <a href="@Nav.Uri" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-arrow-clockwise me-1"></i>Reload page
                            </a>
                        </div>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </article>
    </main>
</div>

@code {
    private bool _isDark;
    private IJSObjectReference? _signalRConnection;

    protected override async Task OnInitializedAsync()
    {
        // Resolve auth state once and reuse throughout this method
        var auth   = await AuthState.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!TenantCtx.IsResolved)
        {
            var slug = new Uri(Nav.Uri).AbsolutePath.Trim('/').Split('/').FirstOrDefault();
            if (!string.IsNullOrEmpty(slug))
            {
                var tenant = await TenantService.ResolveBySlugAsync(slug);
                if (tenant is not null)
                {
                    // Security: verify the authenticated user belongs to this tenant.
                    // SuperAdmin is exempt (cross-tenant by design).
                    if (auth.User.Identity?.IsAuthenticated == true &&
                        !auth.User.IsInRole("SuperAdmin") &&
                        userId is not null)
                    {
                        var appUser = await UserMgr.FindByIdAsync(userId);
                        if (appUser is null || appUser.TenantId != tenant.Id)
                        {
                            Nav.NavigateTo("/access-denied", replace: true);
                            return;
                        }
                    }

                    TenantCtx.TenantId      = tenant.Id;
                    TenantCtx.TenantSlug    = tenant.Slug;
                    TenantCtx.TenantName    = tenant.Name;
                    TenantCtx.PrimaryColour = tenant.PrimaryColour;
                    TenantCtx.LogoUrl       = tenant.LogoUrl;
                    TenantCtx.IsResolved    = true;
                }
            }
        }

        if (TenantCtx.IsResolved && !GateCtx.IsSelected)
        {
            if (auth.User.Identity?.IsAuthenticated == true)
            {
                var isStaff = auth.User.IsInRole("Security") || auth.User.IsInRole("Receptionist") ||
                              auth.User.IsInRole("Manager")  || auth.User.IsInRole("Admin");
                if (isStaff && userId is not null)
                {
                    try
                    {
                        var user = await UserMgr.FindByIdAsync(userId);
                        if (user?.CurrentEntranceId is not null)
                        {
                            var entrance = await EntranceSvc.GetByIdAsync(user.CurrentEntranceId.Value);
                            if (entrance is not null && entrance.IsActive)
                            {
                                GateCtx.EntranceId   = entrance.Id;
                                GateCtx.EntranceName = entrance.Name;
                            }
                        }
                    }
                    catch { /* gate selection is non-critical */ }

                    if (!GateCtx.IsSelected)
                    {
                        var path = new Uri(Nav.Uri).AbsolutePath;
                        if (!path.Contains("select-gate", StringComparison.OrdinalIgnoreCase))
                        {
                            // Only enforce gate selection if entrances have been configured
                            var activeEntrances = await EntranceSvc.GetActiveAsync();
                            if (activeEntrances.Count > 0)
                                Nav.NavigateTo($"{TenantCtx.RouteBase}/select-gate");
                        }
                    }
                }
            }
        }
    }

    // Fix #4 — context stickiness: reset TenantContext when the user soft-navigates
    // to a different slug so page components re-resolve and re-validate ownership.
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            Nav.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (TenantCtx.IsCustomDomain) return; // custom-domain tenants never change slug
        var newSlug = new Uri(e.Location).AbsolutePath.Trim('/').Split('/').FirstOrDefault() ?? "";
        if (!string.Equals(newSlug, TenantCtx.TenantSlug, StringComparison.OrdinalIgnoreCase))
            TenantCtx.Reset();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Read saved theme
        var theme = await JS.InvokeAsync<string>("themeManager.init");
        _isDark = theme == "dark";
        StateHasChanged();

        // Connect to SignalR notification hub
        if (!string.IsNullOrEmpty(TenantCtx.TenantSlug))
        {
            try
            {
                _signalRConnection = await JS.InvokeAsync<IJSObjectReference>(
                    "eval",
                    $$"""
                    (async function() {
                        const conn = new signalR.HubConnectionBuilder()
                            .withUrl('/hubs/notifications')
                            .withAutomaticReconnect()
                            .build();
                        conn.on('VisitorCheckedIn', (visitorName, purpose, hostName) => {
                            window.notificationManager.show(
                                'Visitor Checked In',
                                `${visitorName} arrived · ${purpose} · Host: ${hostName}`,
                                'success'
                            );
                        });
                        await conn.start();
                        await conn.invoke('JoinTenant', '{{TenantCtx.TenantSlug}}');
                        return conn;
                    })()
                    """);
            }
            catch { /* SignalR optional — swallow connection errors */ }
        }
    }

    private async Task ToggleThemeAsync()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("themeManager.setTheme", _isDark ? "dark" : "light");
    }

    public async ValueTask DisposeAsync()
    {
        Nav.LocationChanged -= HandleLocationChanged;
        try
        {
            if (_signalRConnection is not null)
                await _signalRConnection.InvokeVoidAsync("stop");
        }
        catch { }
    }
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>
