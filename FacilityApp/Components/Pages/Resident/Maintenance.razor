@page "/{TenantSlug}/resident/maintenance"
@page "/resident/maintenance"
@layout ResidentLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = "CanViewOwnHistory")]
@inject IMaintenanceService MaintenanceSvc
@inject IUnitService UnitSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject AuthenticationStateProvider AuthState

@using FacilityApp.Data.Models

<PageTitle>Maintenance — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-tools me-2 text-primary"></i>Maintenance Requests</h4>
        <small class="text-muted">Submit and track repair or issue requests for your unit</small>
    </div>
    @if (!_showForm)
    {
        <button class="btn btn-primary" @onclick="() => _showForm = true">
            <i class="bi bi-plus-lg me-1"></i>New Request
        </button>
    }
</div>

@if (_showForm)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3">
            <h6 class="mb-0 fw-semibold"><i class="bi bi-pencil-square me-2 text-primary"></i>New Maintenance Request</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-medium">Title <span class="text-danger">*</span></label>
                    <input class="form-control" placeholder="Brief description of the issue" @bind="_title" maxlength="120" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-medium">Category</label>
                    <select class="form-select" @bind="_category">
                        @foreach (var c in Enum.GetValues<MaintenanceCategory>())
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-medium">Priority</label>
                    <select class="form-select" @bind="_priority">
                        @foreach (var p in Enum.GetValues<MaintenancePriority>())
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label fw-medium">Description <span class="text-danger">*</span></label>
                    <textarea class="form-control" rows="3" placeholder="Provide details about the issue…" @bind="_description"></textarea>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_formError))
            {
                <div class="alert alert-danger mt-3 mb-0">@_formError</div>
            }
        </div>
        <div class="card-footer bg-white border-top d-flex gap-2 justify-content-end">
            <button class="btn btn-outline-secondary" @onclick="CancelForm" disabled="@_busy">Cancel</button>
            <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@_busy">
                @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Submit Request
            </button>
        </div>
    </div>
}

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border text-primary mb-2"></div>
        <p>Loading…</p>
    </div>
}
else if (_requests.Count == 0 && !_showForm)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-tools fs-1 d-block mb-3 opacity-25"></i>
            <h5>No maintenance requests</h5>
            <p class="mb-3 small">Submit a request if something needs attention in your unit.</p>
            <button class="btn btn-primary" @onclick="() => _showForm = true">
                <i class="bi bi-plus-lg me-1"></i>New Request
            </button>
        </div>
    </div>
}
else if (_requests.Count > 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom py-3">
            <h6 class="mb-0 fw-semibold">My Requests</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Issue</th>
                            <th>Category</th>
                            <th>Priority</th>
                            <th>Submitted</th>
                            <th>Staff Note</th>
                            <th class="text-center pe-3">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _requests)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-medium">@r.Title</div>
                                    <small class="text-muted">@r.Description</small>
                                </td>
                                <td><span class="badge bg-light text-dark border">@r.Category</span></td>
                                <td>@((MarkupString)PriorityBadge(r.Priority))</td>
                                <td class="small text-muted">
                                    @r.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")<br />
                                    @r.CreatedAt.ToLocalTime().ToString("h:mm tt")
                                </td>
                                <td class="small text-muted fst-italic">
                                    @(string.IsNullOrEmpty(r.StaffNote) ? "—" : r.StaffNote)
                                </td>
                                <td class="text-center pe-3">@((MarkupString)StatusBadge(r.Status))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (_toast is not null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100;">
        <div class="toast show align-items-center text-bg-@_toastType border-0 shadow">
            <div class="d-flex">
                <div class="toast-body">@_toast</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => _toast = null"></button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private List<MaintenanceRequest> _requests = [];
    private bool _loading = true;
    private bool _busy;
    private bool _showForm;
    private string _userId = "";
    private Guid? _unitId;

    // Form fields
    private string _title = "";
    private string _description = "";
    private MaintenanceCategory _category = MaintenanceCategory.Other;
    private MaintenancePriority _priority = MaintenancePriority.Medium;
    private string _formError = "";

    private string? _toast;
    private string _toastType = "success";

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        var auth = await AuthState.GetAuthenticationStateAsync();
        _userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        if (!string.IsNullOrEmpty(_userId))
        {
            var units = await UnitSvc.GetForUserAsync(_userId);
            _unitId = units.FirstOrDefault().Unit?.Id;
            _requests = await MaintenanceSvc.GetForResidentAsync(_userId);
        }

        _loading = false;
    }

    private async Task SubmitAsync()
    {
        _formError = "";
        if (string.IsNullOrWhiteSpace(_title))      { _formError = "Title is required."; return; }
        if (string.IsNullOrWhiteSpace(_description)) { _formError = "Description is required."; return; }

        _busy = true;
        try
        {
            await MaintenanceSvc.SubmitAsync(_userId, _unitId, _title, _description, _category, _priority);
            _requests = await MaintenanceSvc.GetForResidentAsync(_userId);
            CancelForm();
            ShowToast("Request submitted successfully.", "success");
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally { _busy = false; }
    }

    private void CancelForm()
    {
        _showForm    = false;
        _title       = "";
        _description = "";
        _category    = MaintenanceCategory.Other;
        _priority    = MaintenancePriority.Medium;
        _formError   = "";
    }

    private void ShowToast(string message, string type)
    {
        _toast     = message;
        _toastType = type;
        _ = Task.Delay(4000).ContinueWith(_ =>
        {
            _toast = null;
            InvokeAsync(StateHasChanged);
        });
    }

    private static string PriorityBadge(MaintenancePriority p) => p switch
    {
        MaintenancePriority.Low    => "<span class=\"badge bg-secondary\">Low</span>",
        MaintenancePriority.Medium => "<span class=\"badge bg-info text-dark\">Medium</span>",
        MaintenancePriority.High   => "<span class=\"badge bg-warning text-dark\">High</span>",
        MaintenancePriority.Urgent => "<span class=\"badge bg-danger\">Urgent</span>",
        _                          => "<span class=\"badge bg-light text-dark\">—</span>"
    };

    private static string StatusBadge(MaintenanceStatus s) => s switch
    {
        MaintenanceStatus.Open       => "<span class=\"badge bg-primary\">Open</span>",
        MaintenanceStatus.InProgress => "<span class=\"badge bg-warning text-dark\">In Progress</span>",
        MaintenanceStatus.Resolved   => "<span class=\"badge bg-success\">Resolved</span>",
        MaintenanceStatus.Closed     => "<span class=\"badge bg-secondary\">Closed</span>",
        _                            => "<span class=\"badge bg-light text-dark\">—</span>"
    };
}
