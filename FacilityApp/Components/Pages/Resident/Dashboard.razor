@page "/{TenantSlug}/resident"
@page "/resident"
@layout ResidentLayout
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanViewOwnHistory")]
@inject IVisitorService VisitorSvc
@inject IUnitService UnitSvc
@inject IUnitRequestService RequestSvc
@inject IAnnouncementService AnnouncementSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

@using FacilityApp.Data.Models

<PageTitle>My Dashboard — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-speedometer2 me-2 text-primary"></i>My Dashboard</h4>
        <small class="text-muted">Welcome back, @_userName</small>
    </div>
    <AuthorizeView Policy="CanPreRegisterVisits">
        <Authorized>
            <a href="@(TenantCtx.RouteBase)/resident/preregister" class="btn btn-primary">
                <i class="bi bi-person-plus me-1"></i>Pre-register Visitor
            </a>
        </Authorized>
        <NotAuthorized>
            @if (_pendingRequest is not null)
            {
                <span class="badge bg-warning text-dark py-2 px-3">
                    <i class="bi bi-hourglass-split me-1"></i>Unit request pending review
                </span>
            }
            else
            {
                <a href="@(TenantCtx.RouteBase)/resident/request-unit" class="btn btn-warning">
                    <i class="bi bi-house-add me-1"></i>Request Your Unit
                </a>
            }
        </NotAuthorized>
    </AuthorizeView>
</div>

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border text-primary mb-2"></div>
        <p>Loading…</p>
    </div>
}
else
{
    <!-- Summary cards -->
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-primary">@_upcoming.Count</div>
                <div class="text-muted small">Upcoming</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-success">@_visits.Count(v => v.Status == VisitStatus.CheckedIn)</div>
                <div class="text-muted small">Currently Inside</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-secondary">@_visits.Count</div>
                <div class="text-muted small">Total Visits</div>
            </div>
        </div>
    </div>

    <!-- Announcements -->
    @if (_announcements.Count > 0)
    {
        <div class="mb-4">
            @foreach (var a in _announcements)
            {
                <div class="alert @AnnouncementAlertClass(a.Category) d-flex gap-3 align-items-start mb-2 shadow-sm" role="alert">
                    <i class="bi @AnnouncementIcon(a.Category) fs-5 mt-1"></i>
                    <div>
                        <div class="fw-semibold">@a.Title</div>
                        <div class="small">@a.Body</div>
                        <div class="small opacity-75 mt-1">@a.PublishedAt.ToLocalTime().ToString("MMM d, yyyy")</div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Upcoming visits -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-semibold">
                <i class="bi bi-clock me-2 text-primary"></i>Upcoming Visits
            </h6>
            <a href="@(TenantCtx.RouteBase)/resident/visits" class="btn btn-sm btn-outline-secondary">
                View All <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
        <div class="card-body p-0">
            @if (_upcoming.Count == 0)
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-calendar-x fs-1 d-block mb-2 opacity-25"></i>
                    No upcoming visits scheduled.
                    <AuthorizeView Policy="CanPreRegisterVisits">
                        <Authorized>
                            <div class="mt-2">
                                <a href="@(TenantCtx.RouteBase)/resident/preregister" class="btn btn-sm btn-primary">
                                    <i class="bi bi-person-plus me-1"></i>Pre-register a Visitor
                                </a>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Visitor</th>
                                <th>Purpose</th>
                                <th>Scheduled</th>
                                <th class="text-center">Status</th>
                                <th class="text-end pe-3">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in _upcoming)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="fw-medium">@v.Visitor.FullName</div>
                                        <small class="text-muted">@v.Visitor.Email</small>
                                    </td>
                                    <td><span class="badge bg-light text-dark border">@v.Purpose</span></td>
                                    <td class="small">@v.ScheduledAt.ToLocalTime().ToString("MMM d, h:mm tt")</td>
                                    <td class="text-center">@((MarkupString)StatusBadge(v.Status))</td>
                                    <td class="text-end pe-3">
                                        @if (v.Status == VisitStatus.Scheduled)
                                        {
                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => CancelAsync(v.Id)"
                                                    disabled="@_busy">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Quick actions -->
    <div class="row g-3">
        <div class="col-md-4">
            <a href="@(TenantCtx.RouteBase)/resident/preregister" class="card border-0 shadow-sm text-decoration-none h-100 quick-action-card">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="quick-icon bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-person-plus"></i>
                    </div>
                    <div>
                        <div class="fw-semibold text-dark">Pre-register Visitor</div>
                        <small class="text-muted">Schedule a visit in advance</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="@(TenantCtx.RouteBase)/resident/visits" class="card border-0 shadow-sm text-decoration-none h-100 quick-action-card">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="quick-icon bg-success bg-opacity-10 text-success">
                        <i class="bi bi-calendar-check"></i>
                    </div>
                    <div>
                        <div class="fw-semibold text-dark">My Visits</div>
                        <small class="text-muted">View your visit history</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="@(TenantCtx.RouteBase)/resident/maintenance" class="card border-0 shadow-sm text-decoration-none h-100 quick-action-card">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="quick-icon bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-tools"></i>
                    </div>
                    <div>
                        <div class="fw-semibold text-dark">Maintenance</div>
                        <small class="text-muted">Submit or track repair requests</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="@(TenantCtx.RouteBase)/resident/profile" class="card border-0 shadow-sm text-decoration-none h-100 quick-action-card">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="quick-icon bg-info bg-opacity-10 text-info">
                        <i class="bi bi-house-door"></i>
                    </div>
                    <div>
                        <div class="fw-semibold text-dark">
                            @if (_myUnit is not null)
                            {
                                @(_myUnit.Block is not null
                                    ? $"Unit {_myUnit.Block}-{_myUnit.UnitNumber}"
                                    : $"Unit {_myUnit.UnitNumber}")
                            }
                            else
                            {
                                <span>My Profile</span>
                            }
                        </div>
                        <small class="text-muted">@(TenantCtx.TenantName) · View profile</small>
                    </div>
                </div>
            </a>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private List<Visit> _visits = [];
    private List<Visit> _upcoming = [];
    private List<Announcement> _announcements = [];
    private string _userName = "";
    private string _userId = "";
    private bool _loading = true;
    private bool _busy;
    private Unit? _myUnit;
    private UnitRequest? _pendingRequest;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        var auth = await AuthState.GetAuthenticationStateAsync();
        var user  = auth.User;

        // Staff users land on the staff dashboard, not the resident portal
        bool isStaff = user.IsInRole(Program.RoleAdmin) || user.IsInRole(Program.RoleManager) ||
                       user.IsInRole(Program.RoleReceptionist) || user.IsInRole(Program.RoleSecurity);
        if (isStaff)
        {
            Nav.NavigateTo($"{TenantCtx.RouteBase}/dashboard", replace: true);
            return;
        }

        _userName = user.Identity?.Name ?? "";
        _userId   = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        if (!string.IsNullOrEmpty(_userId))
        {
            _visits   = await VisitorSvc.GetVisitsForHostAsync(_userId);
            _upcoming = _visits
                .Where(v => v.Status == VisitStatus.Scheduled && v.ScheduledAt >= DateTime.UtcNow)
                .OrderBy(v => v.ScheduledAt)
                .ToList();
            var units = await UnitSvc.GetForUserAsync(_userId);
            _myUnit = units.FirstOrDefault().Unit;
            if (_myUnit is null)
                _pendingRequest = await RequestSvc.GetForResidentAsync(_userId);
        }
        _announcements = await AnnouncementSvc.GetActiveAsync();
        _loading = false;
    }

    private async Task CancelAsync(Guid visitId)
    {
        _busy = true;
        await VisitorSvc.CancelAsync(visitId);
        _visits   = await VisitorSvc.GetVisitsForHostAsync(_userId);
        _upcoming = _visits
            .Where(v => v.Status == VisitStatus.Scheduled && v.ScheduledAt >= DateTime.UtcNow)
            .OrderBy(v => v.ScheduledAt)
            .ToList();
        _busy = false;
    }

    private static string AnnouncementAlertClass(AnnouncementCategory c) => c switch
    {
        AnnouncementCategory.Urgent      => "alert-danger",
        AnnouncementCategory.Maintenance => "alert-warning",
        AnnouncementCategory.Event       => "alert-info",
        _                                => "alert-secondary"
    };

    private static string AnnouncementIcon(AnnouncementCategory c) => c switch
    {
        AnnouncementCategory.Urgent      => "bi-exclamation-triangle-fill",
        AnnouncementCategory.Maintenance => "bi-tools",
        AnnouncementCategory.Event       => "bi-calendar-event",
        _                                => "bi-megaphone-fill"
    };

    private static string StatusBadge(VisitStatus s) => s switch
    {
        VisitStatus.Scheduled  => "<span class=\"badge bg-primary\">Scheduled</span>",
        VisitStatus.CheckedIn  => "<span class=\"badge bg-success\">Checked In</span>",
        VisitStatus.CheckedOut => "<span class=\"badge bg-secondary\">Checked Out</span>",
        VisitStatus.Cancelled  => "<span class=\"badge bg-danger\">Cancelled</span>",
        VisitStatus.NoShow     => "<span class=\"badge bg-warning text-dark\">No Show</span>",
        _                      => "<span class=\"badge bg-light text-dark\">Unknown</span>"
    };
}
