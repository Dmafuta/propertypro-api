@page "/{TenantSlug}/resident/documents"
@page "/resident/documents"
@layout ResidentLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = "CanViewOwnHistory")]
@inject IDocumentService DocumentSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx

@using FacilityApp.Data.Models

<PageTitle>Documents — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-folder2-open me-2 text-primary"></i>Documents</h4>
        <small class="text-muted">Official documents, rules, and notices from management</small>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border text-primary mb-2"></div>
        <p>Loading…</p>
    </div>
}
else if (_docs.Count == 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-folder2-open fs-1 d-block mb-3 opacity-25"></i>
            <h5>No documents available</h5>
            <p class="small">Management hasn't published any documents yet.</p>
        </div>
    </div>
}
else
{
    @foreach (var group in _docs.GroupBy(d => d.Category).OrderBy(g => g.Key.ToString()))
    {
        <div class="mb-4">
            <h6 class="text-uppercase fw-semibold text-muted mb-3" style="font-size:0.75rem;letter-spacing:0.08em;">
                <i class="bi @CategoryIcon(group.Key) me-2"></i>@group.Key
            </h6>
            <div class="card border-0 shadow-sm">
                <div class="list-group list-group-flush">
                    @foreach (var d in group.OrderByDescending(d => d.UploadedAt))
                    {
                        <div class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3">
                            <div class="flex-shrink-0 text-primary fs-3">
                                <i class="bi @FileIcon(d.OriginalFileName)"></i>
                            </div>
                            <div class="flex-grow-1 min-w-0">
                                <div class="fw-medium">@d.Title</div>
                                @if (!string.IsNullOrEmpty(d.Description))
                                {
                                    <small class="text-muted">@d.Description</small>
                                }
                                <div class="mt-1">
                                    <small class="text-muted">
                                        @FormatSize(d.FileSize) &middot; @d.UploadedAt.ToLocalTime().ToString("MMM d, yyyy")
                                    </small>
                                </div>
                            </div>
                            <a href="/documents/@TenantCtx.TenantSlug/@d.StoredFileName"
                               download="@d.OriginalFileName"
                               class="btn btn-sm btn-outline-primary flex-shrink-0">
                                <i class="bi bi-download me-1"></i>Download
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private List<Document> _docs = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        _docs    = await DocumentSvc.GetActiveAsync();
        _loading = false;
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        >= 1_048_576 => $"{bytes / 1_048_576.0:0.#} MB",
        >= 1_024     => $"{bytes / 1_024.0:0.#} KB",
        _            => $"{bytes} B"
    };

    private static string FileIcon(string fileName)
    {
        var ext = Path.GetExtension(fileName).ToLowerInvariant();
        return ext switch
        {
            ".pdf"              => "bi-file-earmark-pdf",
            ".doc" or ".docx"   => "bi-file-earmark-word",
            ".xls" or ".xlsx"   => "bi-file-earmark-excel",
            ".jpg" or ".jpeg"
                or ".png"       => "bi-file-earmark-image",
            ".txt"              => "bi-file-earmark-text",
            _                   => "bi-file-earmark"
        };
    }

    private static string CategoryIcon(DocumentCategory c) => c switch
    {
        DocumentCategory.Rules   => "bi-shield-check",
        DocumentCategory.Levy    => "bi-cash-coin",
        DocumentCategory.Bylaws  => "bi-journal-bookmark",
        DocumentCategory.Notice  => "bi-megaphone",
        _                        => "bi-folder2"
    };
}
