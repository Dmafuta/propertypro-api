@page "/{TenantSlug}/resident/preregister"
@page "/resident/preregister"
@layout ResidentLayout
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanPreRegisterVisits")]
@inject IVisitorService VisitorSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject AuthenticationStateProvider AuthState
@inject IQrCodeService QrSvc

<PageTitle>Pre-register Visitor — @TenantCtx.TenantName</PageTitle>

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="@(TenantCtx.RouteBase)/resident" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-person-plus me-2 text-primary"></i>Pre-register Visitor</h4>
        <small class="text-muted">Schedule a visitor to your unit in advance</small>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <EditForm Model="_form" OnValidSubmit="SubmitAsync" FormName="resident-preregister">
            <DataAnnotationsValidator />

            @if (_error is not null)
            {
                <div class="alert alert-danger py-2 small mb-3">
                    <i class="bi bi-exclamation-triangle me-1"></i>@_error
                </div>
            }
            @if (_success is not null)
            {
                <div class="alert alert-success mb-3">
                    <i class="bi bi-check-circle me-2"></i><strong>Visit scheduled!</strong>
                    <div class="mt-1 small">@_success</div>
                    <div class="mt-2">
                        <a href="@(TenantCtx.RouteBase)/resident/visits" class="btn btn-sm btn-outline-success me-2">View My Visits</a>
                        <button type="button" class="btn btn-sm btn-success" @onclick="RegisterAnother">Register Another</button>
                    </div>
                </div>
                @if (_visitQr is not null)
                {
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-body text-center py-3">
                            <h6 class="fw-semibold mb-1"><i class="bi bi-qr-code me-2 text-primary"></i>Visitor QR Code</h6>
                            <p class="text-muted small mb-3">Share this QR code with your visitor. Security can scan it at the gate for fast check-in.</p>
                            <img src="@_visitQr" alt="Visitor QR Code"
                                 style="width:180px;height:180px;image-rendering:pixelated;" class="border rounded p-1" />
                            <div class="mt-2">
                                <small class="text-muted">Visit ID: <code style="font-size:0.7rem;">@_visitId</code></small>
                            </div>
                        </div>
                    </div>
                }
            }

            @if (_success is null)
            {
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="mb-0 fw-semibold"><i class="bi bi-person me-2 text-primary"></i>Visitor Details</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Full Name <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_form.FullName" placeholder="Jane Doe" />
                                <ValidationMessage For="() => _form.FullName" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Email Address <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_form.Email" placeholder="jane@example.com" autocomplete="off" />
                                <ValidationMessage For="() => _form.Email" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Phone <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_form.Phone" placeholder="+1 555 000 0000" />
                                <ValidationMessage For="() => _form.Phone" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Company</label>
                                <InputText class="form-control" @bind-Value="_form.Company" placeholder="Acme Corp (optional)" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="mb-0 fw-semibold"><i class="bi bi-calendar-event me-2 text-primary"></i>Visit Details</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-medium small">Purpose <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_form.Purpose"
                                           placeholder="e.g. Personal visit, Maintenance, Delivery" />
                                <ValidationMessage For="() => _form.Purpose" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Date <span class="text-danger">*</span></label>
                                <InputDate class="form-control" @bind-Value="_form.VisitDate" />
                                <ValidationMessage For="() => _form.VisitDate" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Time <span class="text-danger">*</span></label>
                                <input type="time" class="form-control" @bind="_visitTime" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium small">Notes <span class="text-muted fw-normal">(optional)</span></label>
                                <InputTextArea class="form-control" @bind-Value="_form.Notes" rows="2"
                                               placeholder="e.g. Please direct to Unit 4B, Gate access required…" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" disabled="@_busy">
                        @if (_busy)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        else
                        {
                            <i class="bi bi-calendar-plus me-2"></i>
                        }
                        Schedule Visit
                    </button>
                    <a href="@(TenantCtx.RouteBase)/resident" class="btn btn-outline-secondary">Cancel</a>
                </div>
            }
        </EditForm>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 bg-light">
            <div class="card-body py-4">
                <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>About Pre-registration</h6>
                <ul class="list-unstyled small text-muted mb-0">
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Your visitor is expected and the visit is <strong>Scheduled</strong>.</li>
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Security or reception will check them in on arrival.</li>
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>You are automatically set as the host.</li>
                    <li><i class="bi bi-check2 text-success me-2"></i>You can cancel from <strong>My Visits</strong> if plans change.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private PreRegForm _form = new();
    private TimeOnly _visitTime = new TimeOnly(10, 0);
    private string _userId = "";
    private string? _error;
    private string? _success;
    private string? _visitQr;
    private Guid? _visitId;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        var auth = await AuthState.GetAuthenticationStateAsync();
        _userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
    }

    private async Task SubmitAsync()
    {
        _busy  = true;
        _error = null;

        try
        {
            var scheduledLocal = _form.VisitDate.ToDateTime(_visitTime);
            var scheduledAt    = DateTime.SpecifyKind(scheduledLocal, DateTimeKind.Local).ToUniversalTime();

            if (scheduledAt < DateTime.UtcNow)
            {
                _error = "Scheduled date and time cannot be in the past.";
                _busy  = false;
                return;
            }

            var visit = await VisitorSvc.PreRegisterAsync(
                _form.FullName, _form.Email, _form.Phone, _form.Company,
                _form.Purpose, _userId, scheduledAt, _form.Notes);

            _visitId  = visit.Id;
            _visitQr  = QrSvc.GenerateVisitQr(visit.Id);
            _success  = $"{_form.FullName} is scheduled to visit on {scheduledAt.ToLocalTime():MMM d, yyyy} at {scheduledAt.ToLocalTime():h:mm tt}.";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private void RegisterAnother()
    {
        _form      = new PreRegForm();
        _visitTime = new TimeOnly(10, 0);
        _success   = null;
        _error     = null;
        _visitQr   = null;
        _visitId   = null;
    }

    private sealed class PreRegForm
    {
        [Required(ErrorMessage = "Full name is required.")]
        [MaxLength(100)]
        public string FullName { get; set; } = "";

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Phone number is required.")]
        [MaxLength(30)]
        public string Phone { get; set; } = "";

        [MaxLength(100)]
        public string? Company { get; set; }

        [Required(ErrorMessage = "Purpose is required.")]
        [MaxLength(100)]
        public string Purpose { get; set; } = "";

        [MaxLength(500)]
        public string? Notes { get; set; }

        public DateOnly VisitDate { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddDays(1));
    }
}
