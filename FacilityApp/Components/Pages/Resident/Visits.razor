@page "/{TenantSlug}/resident/visits"
@page "/resident/visits"
@layout ResidentLayout
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanViewOwnHistory")]
@inject IVisitorService VisitorSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject AuthenticationStateProvider AuthState
@inject IQrCodeService QrSvc

<PageTitle>My Visits — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-calendar-check me-2 text-primary"></i>My Visits</h4>
        <small class="text-muted">All visitors you have pre-registered</small>
    </div>
    <AuthorizeView Policy="CanPreRegisterVisits">
        <Authorized>
            <a href="@(TenantCtx.RouteBase)/resident/preregister" class="btn btn-primary btn-sm">
                <i class="bi bi-person-plus me-1"></i>Pre-register New
            </a>
        </Authorized>
    </AuthorizeView>
</div>

<!-- Filter tabs + search -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom py-0">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <ul class="nav nav-tabs border-0 mb-0">
                @foreach (var (key, label) in Tabs)
                {
                    <li class="nav-item">
                        <button class="nav-link @(_activeTab == key ? "active" : "")"
                                @onclick="() => SetTab(key)">@label</button>
                    </li>
                }
            </ul>
            <div style="width:220px;" class="my-1">
                <input class="form-control form-control-sm" placeholder="Search visitor, purpose…"
                       @bind="_search" @bind:event="oninput" />
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-5 text-muted">
                <div class="spinner-border spinner-border-sm me-2"></div>Loading…
            </div>
        }
        else if (Filtered.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-calendar-x fs-1 d-block mb-2 opacity-25"></i>
                No visits in this category.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Visitor</th>
                            <th>Company</th>
                            <th>Purpose</th>
                            <th>Scheduled</th>
                            <th>Check-in</th>
                            <th class="text-center">Status</th>
                            <th class="text-end pe-3">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in PagedItems)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-medium">@v.Visitor.FullName</div>
                                    <small class="text-muted">@v.Visitor.Email</small>
                                </td>
                                <td class="small text-muted">@(v.Visitor.Company ?? "—")</td>
                                <td><span class="badge bg-light text-dark border">@v.Purpose</span></td>
                                <td class="small">@v.ScheduledAt.ToLocalTime().ToString("MMM d, h:mm tt")</td>
                                <td class="small text-muted">
                                    @(v.CheckedInAt.HasValue ? v.CheckedInAt.Value.ToLocalTime().ToString("h:mm tt") : "—")
                                </td>
                                <td class="text-center">@((MarkupString)StatusBadge(v.Status))</td>
                                <td class="text-end pe-3">
                                    @if (v.Status == VisitStatus.Scheduled)
                                    {
                                        <button class="btn btn-sm btn-outline-primary me-1"
                                                @onclick="() => ShowQr(v.Id)"
                                                title="Show QR code">
                                            <i class="bi bi-qr-code"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => CancelAsync(v.Id)"
                                                disabled="@_busy"
                                                title="Cancel visit">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-3 py-2 border-top d-flex justify-content-between align-items-center">
                <small class="text-muted">@Filtered.Count result@(Filtered.Count == 1 ? "" : "s")</small>
                @if (TotalPages > 1)
                {
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(_page==1?"disabled":"")">
                            <button class="page-link" @onclick="() => _page--">‹</button>
                        </li>
                        @for (var i = 1; i <= TotalPages; i++)
                        {
                            var p = i;
                            <li class="page-item @(_page==p?"active":"")">
                                <button class="page-link" @onclick="() => _page = p">@p</button>
                            </li>
                        }
                        <li class="page-item @(_page==TotalPages?"disabled":"")">
                            <button class="page-link" @onclick="() => _page++">›</button>
                        </li>
                    </ul>
                }
            </div>
        }
    </div>
</div>

@if (_qrDataUrl is not null)
{
    <!-- QR Code modal backdrop -->
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);" @onclick="CloseQr">
        <div class="modal-dialog modal-sm modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-semibold"><i class="bi bi-qr-code me-2 text-primary"></i>Visitor QR Code</h6>
                    <button type="button" class="btn-close" @onclick="CloseQr"></button>
                </div>
                <div class="modal-body text-center pt-2">
                    <p class="text-muted small mb-3">Share with your visitor. Security scans this at the gate.</p>
                    <img src="@_qrDataUrl" alt="QR Code"
                         style="width:200px;height:200px;image-rendering:pixelated;" class="border rounded p-1 mb-2" />
                    <div><small class="text-muted" style="font-size:0.65rem;">@_qrVisitId</small></div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private static readonly (string Key, string Label)[] Tabs =
    [
        ("upcoming", "Upcoming"),
        ("active",   "Active"),
        ("history",  "History"),
        ("all",      "All"),
    ];

    private List<Visit> _all = [];
    private string _activeTab = "upcoming";
    private string _userId = "";
    private bool _loading = true;
    private bool _busy;
    private string? _search;
    private int _page = 1;
    private const int PageSize = 15;

    private string? _qrDataUrl;
    private Guid? _qrVisitId;

    private List<Visit> Filtered
    {
        get
        {
            IEnumerable<Visit> q = _activeTab switch
            {
                "upcoming" => _all.Where(v => v.Status == VisitStatus.Scheduled && v.ScheduledAt >= DateTime.UtcNow)
                                 .OrderBy(v => v.ScheduledAt),
                "active"   => _all.Where(v => v.Status == VisitStatus.CheckedIn)
                                 .OrderByDescending(v => v.CheckedInAt),
                "history"  => _all.Where(v => v.Status is VisitStatus.CheckedOut or VisitStatus.NoShow or VisitStatus.Cancelled)
                                 .OrderByDescending(v => v.ScheduledAt),
                _          => _all.OrderByDescending(v => v.ScheduledAt)
            };

            if (!string.IsNullOrWhiteSpace(_search))
            {
                var s = _search.Trim().ToLower();
                q = q.Where(v =>
                    v.Visitor.FullName.ToLower().Contains(s) ||
                    v.Visitor.Email.ToLower().Contains(s) ||
                    v.Purpose.ToLower().Contains(s) ||
                    (v.Visitor.Company != null && v.Visitor.Company.ToLower().Contains(s)));
            }

            return q.ToList();
        }
    }

    private int TotalPages => (int)Math.Ceiling(Filtered.Count / (double)PageSize);
    private List<Visit> PagedItems => Filtered.Skip((_page - 1) * PageSize).Take(PageSize).ToList();

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        var auth = await AuthState.GetAuthenticationStateAsync();
        _userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        if (!string.IsNullOrEmpty(_userId))
            _all = await VisitorSvc.GetVisitsForHostAsync(_userId);

        _loading = false;
    }

    private void SetTab(string tab) { _activeTab = tab; _page = 1; }

    private void ShowQr(Guid visitId)
    {
        _qrVisitId  = visitId;
        _qrDataUrl  = QrSvc.GenerateVisitQr(visitId);
    }

    private void CloseQr()
    {
        _qrDataUrl = null;
        _qrVisitId = null;
    }

    private async Task CancelAsync(Guid visitId)
    {
        _busy = true;
        await VisitorSvc.CancelAsync(visitId);
        _all  = await VisitorSvc.GetVisitsForHostAsync(_userId);
        _busy = false;
    }

    private static string StatusBadge(VisitStatus s) => s switch
    {
        VisitStatus.Scheduled  => "<span class=\"badge bg-primary\">Scheduled</span>",
        VisitStatus.CheckedIn  => "<span class=\"badge bg-success\">Checked In</span>",
        VisitStatus.CheckedOut => "<span class=\"badge bg-secondary\">Checked Out</span>",
        VisitStatus.Cancelled  => "<span class=\"badge bg-danger\">Cancelled</span>",
        VisitStatus.NoShow     => "<span class=\"badge bg-warning text-dark\">No Show</span>",
        _                      => "<span class=\"badge bg-light text-dark\">Unknown</span>"
    };
}
