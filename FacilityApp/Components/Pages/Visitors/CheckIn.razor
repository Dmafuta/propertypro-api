@page "/{TenantSlug}/visitors/checkin"
@page "/visitors/checkin"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanCheckInVisitors")]
@inject IVisitorService VisitorSvc
@inject IAccessPassService PassSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject NavigationManager Nav
@inject IWebHostEnvironment Env
@inject IQrCodeService QrSvc

<PageTitle>Check In Visitor — @TenantCtx.TenantName</PageTitle>

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="@(TenantCtx.RouteBase)/visitors" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-person-check me-2 text-success"></i>Check In Visitor</h4>
        <small class="text-muted">Walk-in or check in a pre-scheduled visit</small>
    </div>
</div>

<!-- Mode tabs -->
<div class="checkin-tabs mb-4">
    <button class="checkin-tab @(_mode == Mode.WalkIn ? "active" : "")"
            @onclick="() => { _mode = Mode.WalkIn; _success = null; _error = null; }">
        <i class="bi bi-person-walking me-2"></i>Walk-In
    </button>
    <button class="checkin-tab @(_mode == Mode.Scheduled ? "active" : "")"
            @onclick="() => SwitchToScheduledAsync()">
        <i class="bi bi-calendar-check me-2"></i>From Schedule
    </button>
    <button class="checkin-tab @(_mode == Mode.QrScan ? "active" : "")"
            @onclick="SwitchToQrScan">
        <i class="bi bi-qr-code-scan me-2"></i>QR Scan
    </button>
</div>

@if (_mode == Mode.WalkIn)
{
    <!-- Walk-In Form -->
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-person-fill me-2 text-primary"></i>Visitor Details</h6>
                </div>
                <div class="card-body">
                    <EditForm Model="_walkIn" OnValidSubmit="SubmitWalkInAsync" FormName="walkin">
                        <DataAnnotationsValidator />

                        @if (_blocked)
                        {
                            <div class="alert alert-danger mb-3">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span class="badge bg-danger fs-6">BLOCKED</span>
                                    <strong>Entry Denied</strong>
                                </div>
                                <div>@_error</div>
                                <small class="text-muted">Contact a manager to override or update the blacklist.</small>
                            </div>
                        }
                        else if (_error is not null)
                        {
                            <div class="alert alert-danger py-2 small mb-3">
                                <i class="bi bi-exclamation-triangle me-1"></i>@_error
                            </div>
                        }
                        @if (_success is not null)
                        {
                            <div class="alert alert-success py-2 small mb-3">
                                <i class="bi bi-check-circle me-1"></i>@_success
                            </div>
                        }

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Full Name <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_walkIn.FullName" placeholder="Jane Doe" />
                                <ValidationMessage For="() => _walkIn.FullName" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Email Address <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_walkIn.Email" placeholder="jane@example.com" autocomplete="off" />
                                <ValidationMessage For="() => _walkIn.Email" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Phone <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_walkIn.Phone" placeholder="+1 555 000 0000" />
                                <ValidationMessage For="() => _walkIn.Phone" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Company</label>
                                <InputText class="form-control" @bind-Value="_walkIn.Company" placeholder="Acme Corp (optional)" />
                            </div>
                        </div>

                        <hr class="my-3" />

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Purpose <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_walkIn.Purpose" placeholder="e.g. Delivery, Meeting, Maintenance" />
                                <ValidationMessage For="() => _walkIn.Purpose" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Host (optional)</label>
                                <InputSelect class="form-select" @bind-Value="_walkIn.HostUserId">
                                    <option value="">— No host —</option>
                                    @if (_hosts is not null)
                                    {
                                        @foreach (var h in _hosts)
                                        {
                                            <option value="@h.Id">@h.FullName (@h.UserType)</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium small">Notes</label>
                                <InputTextArea class="form-control" @bind-Value="_walkIn.Notes" rows="2"
                                               placeholder="Any additional notes (optional)" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium small">Photo <span class="text-muted fw-normal">(optional)</span></label>
                                <InputFile OnChange="OnPhotoSelected" accept="image/*"
                                           class="form-control" />
                                @if (_photoPreview is not null)
                                {
                                    <div class="mt-2">
                                        <img src="@_photoPreview" alt="Preview"
                                             style="height:80px;width:80px;object-fit:cover;border-radius:8px;border:2px solid #dee2e6;" />
                                        <button type="button" class="btn btn-sm btn-outline-danger ms-2"
                                                @onclick="ClearPhoto">Remove</button>
                                    </div>
                                }
                                @if (_photoError is not null)
                                {
                                    <div class="text-danger small mt-1">@_photoError</div>
                                }
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success" disabled="@_busy">
                                @if (_busy)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                else
                                {
                                    <i class="bi bi-person-check-fill me-2"></i>
                                }
                                Check In Now
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="ResetWalkIn">
                                Reset
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <!-- Pass Generation -->
        @if (_lastVisitId.HasValue && !_passIssued)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm border-start border-4 border-primary">
                    <div class="card-body">
                        <h6 class="fw-semibold mb-3"><i class="bi bi-card-checklist me-2 text-primary"></i>Issue Access Pass?</h6>
                        <div class="row g-2 align-items-end">
                            <div class="col-md-3">
                                <label class="form-label small">Pass Type</label>
                                <select class="form-select form-select-sm" @bind="_passType">
                                    <option value="@FacilityApp.Data.Models.PassType.Gate">Gate</option>
                                    <option value="@FacilityApp.Data.Models.PassType.Parking">Parking</option>
                                    <option value="@FacilityApp.Data.Models.PassType.Both">Gate + Parking</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Vehicle Reg.</label>
                                <input class="form-control form-control-sm" @bind="_passVehicle" placeholder="e.g. KAA 001A" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Bay</label>
                                <input class="form-control form-control-sm" @bind="_passBay" placeholder="B12" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Valid Until</label>
                                <input type="datetime-local" class="form-control form-control-sm" @bind="_passValidUntil" />
                            </div>
                            <div class="col-auto d-flex gap-2">
                                <button class="btn btn-sm btn-primary" @onclick="IssuePassAsync" disabled="@_passBusy">
                                    @if (_passBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Issue Pass
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="SkipPass">Skip</button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(_passError))
                        {
                            <div class="text-danger small mt-2">@_passError</div>
                        }
                    </div>
                </div>
            </div>
        }
        @if (_passIssued && !string.IsNullOrEmpty(_issuedPassNumber))
        {
            <div class="col-12">
                <div class="alert alert-primary d-flex align-items-center gap-3 mb-0">
                    <i class="bi bi-card-checklist fs-4"></i>
                    <div>
                        <strong>Pass Issued:</strong> <code>@_issuedPassNumber</code>
                        <div class="small text-muted">Hand the pass number to the visitor.</div>
                    </div>
                </div>
            </div>
        }

        <!-- Tips panel -->
        <div class="col-lg-5">
            <div class="card border-0 bg-light h-100">
                <div class="card-body py-4">
                    <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>Walk-In Check-In</h6>
                    <ul class="list-unstyled small text-muted mb-0">
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Visitor is checked in immediately upon submission.</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>If the visitor has visited before, their record is updated automatically.</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Check out from the Visitors list when they leave.</li>
                        <li><i class="bi bi-check2 text-success me-2"></i>Use <strong>From Schedule</strong> to check in a pre-registered visitor.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
}
else if (_mode == Mode.QrScan)
{
    <!-- QR Scan tab -->
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-qr-code-scan me-2 text-primary"></i>Scan or Enter Visit ID</h6>
                </div>
                <div class="card-body">
                    @if (_error is not null)
                    {
                        <div class="alert alert-danger py-2 small mb-3">
                            <i class="bi bi-exclamation-triangle me-1"></i>@_error
                        </div>
                    }
                    @if (_success is not null)
                    {
                        <div class="alert alert-success py-2 small mb-3">
                            <i class="bi bi-check-circle me-1"></i>@_success
                        </div>
                    }

                    <label class="form-label fw-medium small">Visit ID (scan QR or paste)</label>
                    <div class="input-group mb-3">
                        <input class="form-control font-monospace"
                               placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                               @bind="_qrInput"
                               @bind:event="oninput"
                               @onkeydown="OnQrInputKey" />
                        <button class="btn btn-primary" @onclick="LookupQrAsync" disabled="@_busy">
                            @if (_busy) { <span class="spinner-border spinner-border-sm"></span> }
                            else { <i class="bi bi-search"></i> }
                        </button>
                    </div>

                    @if (_qrVisit is not null)
                    {
                        <div class="card border border-success bg-success bg-opacity-10 mb-3">
                            <div class="card-body py-3">
                                <div class="d-flex align-items-center gap-3 mb-2">
                                    <div class="visitor-avatar">@_qrVisit.Visitor.FullName[0].ToString().ToUpper()</div>
                                    <div>
                                        <div class="fw-semibold">@_qrVisit.Visitor.FullName</div>
                                        <small class="text-muted">@_qrVisit.Visitor.Email · @_qrVisit.Visitor.Phone</small>
                                    </div>
                                </div>
                                <div class="small mb-1"><span class="fw-medium">Purpose:</span> @_qrVisit.Purpose</div>
                                <div class="small mb-1"><span class="fw-medium">Host:</span> @(_qrVisit.Host?.FullName ?? "—")</div>
                                <div class="small mb-3"><span class="fw-medium">Scheduled:</span> @_qrVisit.ScheduledAt.ToLocalTime().ToString("MMM d, h:mm tt")</div>
                                <button class="btn btn-success w-100" @onclick="CheckInQrAsync" disabled="@_busy">
                                    @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    else { <i class="bi bi-person-check-fill me-2"></i> }
                                    Check In @_qrVisit.Visitor.FullName
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 bg-light h-100">
                <div class="card-body py-4">
                    <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>QR Check-In</h6>
                    <ul class="list-unstyled small text-muted mb-0">
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Residents receive a QR code when they pre-register a visitor.</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Use a USB barcode/QR scanner — it types the visit ID automatically.</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Or paste the visit ID from the QR code reader app.</li>
                        <li><i class="bi bi-check2 text-success me-2"></i>Review the visitor details, then click <strong>Check In</strong>.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- Scheduled visits list -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-semibold">
                    <i class="bi bi-calendar-check me-2 text-primary"></i>Scheduled Visits
                </h6>
                <div style="width: 280px;">
                    <input class="form-control form-control-sm"
                           placeholder="Search by name, phone or email…"
                           @bind="_scheduledSearch"
                           @bind:event="oninput" />
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            @if (_scheduledLoading)
            {
                <div class="text-center py-5 text-muted">
                    <div class="spinner-border spinner-border-sm me-2"></div>Loading…
                </div>
            }
            else if (FilteredScheduled.Count == 0)
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-calendar-x fs-1 d-block mb-2 opacity-25"></i>
                    No scheduled visits found.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Visitor</th>
                                <th>Host</th>
                                <th>Purpose</th>
                                <th>Scheduled</th>
                                <th class="text-end pe-3">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var visit in FilteredScheduled)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="visitor-avatar">@visit.Visitor.FullName[0].ToString().ToUpper()</div>
                                            <div>
                                                <div class="fw-medium">@visit.Visitor.FullName</div>
                                                <small class="text-muted">@visit.Visitor.Phone</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="small">@(visit.Host?.FullName ?? "—")</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@visit.Purpose</span>
                                    </td>
                                    <td class="small">
                                        @{
                                            var isOverdue = visit.ScheduledAt < DateTime.UtcNow;
                                        }
                                        <span class="@(isOverdue ? "text-danger" : "")">
                                            @visit.ScheduledAt.ToLocalTime().ToString("MMM d, h:mm tt")
                                        </span>
                                        @if (isOverdue)
                                        {
                                            <span class="badge bg-danger ms-1" style="font-size:0.65rem;">Overdue</span>
                                        }
                                    </td>
                                    <td class="text-end pe-3">
                                        <button class="btn btn-sm btn-success"
                                                @onclick="() => CheckInScheduledAsync(visit.Id)"
                                                disabled="@_busy">
                                            @if (_busy)
                                            {
                                                <span class="spinner-border spinner-border-sm"></span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-person-check me-1"></i>
                                            }
                                            Check In
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private enum Mode { WalkIn, Scheduled, QrScan }
    private Mode _mode = Mode.WalkIn;

    // QR scan state
    private string _qrInput = "";
    private Visit? _qrVisit;

    private WalkInForm  _walkIn  = new();
    private List<ApplicationUser>? _hosts;
    private string? _error;
    private string? _success;
    private bool _busy;
    private bool _blocked;

    // Pass generation
    private Guid? _lastVisitId;
    private bool _passIssued;
    private bool _passBusy;
    private string? _passError;
    private string? _issuedPassNumber;
    private FacilityApp.Data.Models.PassType _passType = FacilityApp.Data.Models.PassType.Gate;
    private string? _passVehicle;
    private string? _passBay;
    private DateTime? _passValidUntil;

    private IBrowserFile? _photoFile;
    private string? _photoPreview;
    private string? _photoError;
    private const long MaxPhotoBytes = 5 * 1024 * 1024; // 5 MB
    private static readonly HashSet<string> AllowedPhotoTypes =
        ["image/jpeg", "image/png", "image/gif", "image/webp"];

    // Scheduled tab state
    private List<Visit>? _scheduledVisits;
    private bool _scheduledLoading;
    private string _scheduledSearch = "";

    private List<Visit> FilteredScheduled =>
        _scheduledVisits?.Where(v =>
            string.IsNullOrWhiteSpace(_scheduledSearch) ||
            v.Visitor.FullName.Contains(_scheduledSearch, StringComparison.OrdinalIgnoreCase) ||
            v.Visitor.Phone.Contains(_scheduledSearch, StringComparison.OrdinalIgnoreCase) ||
            v.Visitor.Email.Contains(_scheduledSearch, StringComparison.OrdinalIgnoreCase)
        ).ToList() ?? [];

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }
        _hosts = await VisitorSvc.GetHostsAsync();
    }

    private async Task SwitchToScheduledAsync()
    {
        _mode    = Mode.Scheduled;
        _success = null;
        _error   = null;

        if (_scheduledVisits is null)
        {
            _scheduledLoading = true;
            _scheduledVisits  = await VisitorSvc.GetScheduledVisitsAsync(null);
            _scheduledLoading = false;
        }
    }

    private async Task SubmitWalkInAsync()
    {
        _busy        = true;
        _error       = null;
        _success     = null;
        _blocked     = false;
        _lastVisitId = null;
        _passIssued  = false;
        _issuedPassNumber = null;
        try
        {
            var hostId   = string.IsNullOrEmpty(_walkIn.HostUserId) ? null : _walkIn.HostUserId;
            var photoUrl = await SavePhotoAsync();

            var visit = await VisitorSvc.WalkInAsync(
                _walkIn.FullName, _walkIn.Email, _walkIn.Phone, _walkIn.Company,
                _walkIn.Purpose, hostId, _walkIn.Notes, photoUrl);

            _success     = $"{_walkIn.FullName} has been checked in successfully.";
            _lastVisitId = visit.Id;
            _walkIn      = new WalkInForm();
            ClearPhoto();
        }
        catch (VisitorBlockedException ex)
        {
            _blocked = true;
            _error   = ex.Message;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task IssuePassAsync()
    {
        _passBusy  = true;
        _passError = null;
        try
        {
            DateTime? validUntilUtc = _passValidUntil.HasValue
                ? DateTime.SpecifyKind(_passValidUntil.Value, DateTimeKind.Local).ToUniversalTime()
                : null;
            var pass = await PassSvc.GenerateAsync(
                _lastVisitId!.Value, _passType, _passVehicle, _passBay, validUntilUtc);
            _issuedPassNumber = pass.PassNumber;
            _passIssued       = true;
        }
        catch (Exception ex)
        {
            _passError = ex.Message;
        }
        finally
        {
            _passBusy = false;
        }
    }

    private void SkipPass()
    {
        _lastVisitId = null;
        _passIssued  = false;
    }

    private async Task<string?> SavePhotoAsync()
    {
        if (_photoFile is null) return null;

        var slug = TenantCtx.TenantSlug;
        var uploadsDir = Path.Combine(Env.WebRootPath, "uploads", slug);
        Directory.CreateDirectory(uploadsDir);

        var ext      = Path.GetExtension(_photoFile.Name).ToLowerInvariant();
        var fileName = $"{Guid.NewGuid()}{ext}";
        var filePath = Path.Combine(uploadsDir, fileName);

        await using var fs = new FileStream(filePath, FileMode.Create);
        await using var stream = _photoFile.OpenReadStream(MaxPhotoBytes);
        await stream.CopyToAsync(fs);

        return $"/uploads/{slug}/{fileName}";
    }

    private async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        _photoError = null;
        var file = e.File;

        if (file.Size > MaxPhotoBytes)
        {
            _photoError = "Photo must be under 5 MB.";
            return;
        }

        if (!AllowedPhotoTypes.Contains(file.ContentType.ToLowerInvariant()))
        {
            _photoError = "Only JPEG, PNG, GIF, or WebP images are allowed.";
            return;
        }

        _photoFile = file;

        // Generate preview as base64
        await using var stream = file.OpenReadStream(MaxPhotoBytes);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());
        _photoPreview = $"data:{file.ContentType};base64,{base64}";
    }

    private void ClearPhoto()
    {
        _photoFile    = null;
        _photoPreview = null;
        _photoError   = null;
    }

    private async Task CheckInScheduledAsync(Guid visitId)
    {
        _busy    = true;
        _blocked = false;
        _error   = null;
        try
        {
            await VisitorSvc.CheckInAsync(visitId);
            _scheduledVisits!.RemoveAll(v => v.Id == visitId);
            _lastVisitId      = visitId;
            _passIssued       = false;
            _issuedPassNumber = null;
        }
        catch (VisitorBlockedException ex)
        {
            _blocked = true;
            _error   = ex.Message;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void ResetWalkIn()
    {
        _walkIn           = new WalkInForm();
        _error            = null;
        _success          = null;
        _blocked          = false;
        _lastVisitId      = null;
        _passIssued       = false;
        _issuedPassNumber = null;
        ClearPhoto();
    }

    private void SwitchToQrScan()
    {
        _mode    = Mode.QrScan;
        _success = null;
        _error   = null;
        _qrInput = "";
        _qrVisit = null;
    }

    private async Task OnQrInputKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await LookupQrAsync();
    }

    private async Task LookupQrAsync()
    {
        _error   = null;
        _success = null;
        _qrVisit = null;

        var raw = _qrInput.Trim();
        if (!Guid.TryParse(raw, out var visitId))
        {
            _error = "Invalid visit ID. Please scan again or check the value.";
            return;
        }

        _busy = true;
        try
        {
            var visits = await VisitorSvc.GetScheduledVisitsAsync(null);
            _qrVisit = visits.FirstOrDefault(v => v.Id == visitId);
            if (_qrVisit is null)
                _error = "Visit not found or is not in Scheduled status.";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task CheckInQrAsync()
    {
        if (_qrVisit is null) return;
        _busy    = true;
        _blocked = false;
        _error   = null;
        try
        {
            await VisitorSvc.CheckInAsync(_qrVisit.Id);
            _success      = $"{_qrVisit.Visitor.FullName} has been checked in successfully.";
            _lastVisitId  = _qrVisit.Id;
            _passIssued   = false;
            _issuedPassNumber = null;
            _qrVisit      = null;
            _qrInput      = "";
        }
        catch (VisitorBlockedException ex) { _blocked = true; _error = ex.Message; }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private sealed class WalkInForm
    {
        [Required(ErrorMessage = "Full name is required.")]
        [MaxLength(100)]
        public string FullName { get; set; } = "";

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Phone number is required.")]
        [MaxLength(30)]
        public string Phone { get; set; } = "";

        [MaxLength(100)]
        public string? Company { get; set; }

        [Required(ErrorMessage = "Purpose is required.")]
        [MaxLength(100)]
        public string Purpose { get; set; } = "";

        public string? HostUserId { get; set; }

        [MaxLength(500)]
        public string? Notes { get; set; }
    }
}
