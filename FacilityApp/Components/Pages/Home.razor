@page "/"
@inject TenantContext TenantCtx

@if (TenantCtx.IsCustomDomain && TenantCtx.IsResolved)
{
    <PageTitle>@TenantCtx.TenantName — Portal</PageTitle>

    <div class="lp-root">

        <!-- Decorative background shapes -->
        <div class="lp-shape lp-shape-1"></div>
        <div class="lp-shape lp-shape-2"></div>
        <div class="lp-shape lp-shape-3"></div>

        <!-- Header -->
        <header class="lp-header">
            <div class="lp-logo">
                @if (!string.IsNullOrEmpty(TenantCtx.LogoUrl))
                {
                    <img src="@TenantCtx.LogoUrl" alt="@TenantCtx.TenantName" class="lp-logo-img" />
                }
                else
                {
                    <div class="lp-logo-icon"><i class="bi bi-buildings"></i></div>
                }
                <span class="lp-logo-name">@TenantCtx.TenantName</span>
            </div>
            <a href="@(TenantCtx.RouteBase)/login" class="btn btn-outline-light btn-sm px-3">
                <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
            </a>
        </header>

        <!-- Hero -->
        <main class="lp-hero">
            <div class="lp-hero-inner">
                <div class="lp-badge mb-3">
                    <i class="bi bi-shield-check me-1"></i>Secure Management Portal
                </div>
                <h1 class="lp-title">@TenantCtx.TenantName</h1>
                <p class="lp-subtitle">
                    Your all-in-one platform for visitor management,<br class="d-none d-md-inline" />
                    resident services and facility operations.
                </p>

                <!-- Portal cards -->
                <div class="lp-cards">
                    <a href="@(TenantCtx.RouteBase)/login" class="lp-card lp-card-staff">
                        <div class="lp-card-icon"><i class="bi bi-person-badge-fill"></i></div>
                        <div class="lp-card-body">
                            <div class="lp-card-title">Staff Portal</div>
                            <div class="lp-card-desc">Receptionists, security &amp; management</div>
                        </div>
                        <i class="bi bi-arrow-right lp-card-arrow"></i>
                    </a>
                    <a href="@(TenantCtx.RouteBase)/resident/login" class="lp-card lp-card-resident">
                        <div class="lp-card-icon"><i class="bi bi-house-heart-fill"></i></div>
                        <div class="lp-card-body">
                            <div class="lp-card-title">Resident Portal</div>
                            <div class="lp-card-desc">Homeowners, tenants &amp; occupants</div>
                        </div>
                        <i class="bi bi-arrow-right lp-card-arrow"></i>
                    </a>
                </div>

                <!-- Feature strip -->
                <div class="lp-features">
                    <div class="lp-feat"><i class="bi bi-qr-code-scan"></i><span>Visitor Check-In</span></div>
                    <div class="lp-feat"><i class="bi bi-calendar-check"></i><span>Pre-Registration</span></div>
                    <div class="lp-feat"><i class="bi bi-car-front-fill"></i><span>Parking</span></div>
                    <div class="lp-feat"><i class="bi bi-box-seam"></i><span>Parcel Tracking</span></div>
                    <div class="lp-feat"><i class="bi bi-tools"></i><span>Maintenance</span></div>
                    <div class="lp-feat"><i class="bi bi-bar-chart-fill"></i><span>Reports</span></div>
                </div>
            </div>
        </main>

        <!-- Footer -->
        <footer class="lp-footer">
            &copy; @DateTime.Now.Year @TenantCtx.TenantName. All rights reserved.
            &nbsp;·&nbsp; Powered by <strong>FacilityApp</strong>
        </footer>
    </div>
}
else
{
    <PageTitle>FacilityApp</PageTitle>

    <div class="lp-root lp-generic">
        <div class="lp-shape lp-shape-1"></div>
        <div class="lp-shape lp-shape-2"></div>
        <div class="lp-generic-inner">
            <div class="lp-logo-icon mb-4"><i class="bi bi-buildings"></i></div>
            <h1 class="lp-title" style="font-size:2.4rem;">FacilityApp</h1>
            <p class="lp-subtitle" style="font-size:1rem;max-width:360px;">
                Visitor &amp; Resident Management Platform
            </p>
            <p class="text-white-50 small mt-3">
                Contact your facility manager for your login link.
            </p>
        </div>
    </div>
}

<style>
    /* ── Root ─────────────────────────────────────── */
    .lp-root {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #0f2744 100%);
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
        color: #fff;
    }

    /* ── Decorative shapes ───────────────────────── */
    .lp-shape {
        position: absolute;
        border-radius: 50%;
        opacity: .07;
        pointer-events: none;
    }
    .lp-shape-1 {
        width: 600px; height: 600px;
        background: #3b82f6;
        top: -200px; right: -150px;
    }
    .lp-shape-2 {
        width: 400px; height: 400px;
        background: #06b6d4;
        bottom: -100px; left: -100px;
    }
    .lp-shape-3 {
        width: 200px; height: 200px;
        background: #a78bfa;
        top: 40%; left: 30%;
    }

    /* ── Header ──────────────────────────────────── */
    .lp-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 2rem;
        position: relative;
        z-index: 2;
    }
    .lp-logo { display: flex; align-items: center; gap: .75rem; }
    .lp-logo-img { height: 36px; width: auto; border-radius: 6px; }
    .lp-logo-icon {
        width: 36px; height: 36px;
        background: rgba(255,255,255,.15);
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem;
    }
    .lp-logo-name { font-weight: 700; font-size: 1rem; letter-spacing: -.01em; }

    /* ── Hero ────────────────────────────────────── */
    .lp-hero {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 1.5rem 2rem;
        position: relative;
        z-index: 2;
    }
    .lp-hero-inner { text-align: center; max-width: 680px; width: 100%; }

    .lp-badge {
        display: inline-flex;
        align-items: center;
        background: rgba(59,130,246,.2);
        border: 1px solid rgba(59,130,246,.4);
        color: #93c5fd;
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .05em;
        text-transform: uppercase;
        padding: .3rem .85rem;
        border-radius: 50px;
    }

    .lp-title {
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: 800;
        letter-spacing: -.03em;
        line-height: 1.1;
        margin-bottom: 1rem;
        background: linear-gradient(135deg, #fff 40%, #93c5fd 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .lp-subtitle {
        font-size: 1.05rem;
        color: rgba(255,255,255,.65);
        line-height: 1.6;
        margin-bottom: 2.5rem;
    }

    /* ── Portal cards ────────────────────────────── */
    .lp-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 2.5rem;
    }
    @media (max-width: 520px) {
        .lp-cards { grid-template-columns: 1fr; }
    }

    .lp-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem 1.4rem;
        border-radius: 16px;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,.1);
        transition: transform .2s, box-shadow .2s, background .2s;
        text-align: left;
    }
    .lp-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 16px 40px rgba(0,0,0,.3);
        text-decoration: none;
    }
    .lp-card-staff {
        background: linear-gradient(135deg, rgba(37,99,235,.5), rgba(29,78,216,.3));
    }
    .lp-card-staff:hover { background: linear-gradient(135deg, rgba(37,99,235,.7), rgba(29,78,216,.5)); }
    .lp-card-resident {
        background: linear-gradient(135deg, rgba(5,150,105,.4), rgba(4,120,87,.3));
    }
    .lp-card-resident:hover { background: linear-gradient(135deg, rgba(5,150,105,.6), rgba(4,120,87,.5)); }

    .lp-card-icon {
        font-size: 1.8rem;
        flex-shrink: 0;
        width: 52px; height: 52px;
        background: rgba(255,255,255,.12);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
    }
    .lp-card-body { flex: 1; }
    .lp-card-title { font-size: 1rem; font-weight: 700; color: #fff; }
    .lp-card-desc  { font-size: .8rem; color: rgba(255,255,255,.6); margin-top: .2rem; }
    .lp-card-arrow { color: rgba(255,255,255,.4); font-size: 1.1rem; transition: transform .2s; }
    .lp-card:hover .lp-card-arrow { transform: translateX(4px); color: rgba(255,255,255,.8); }

    /* ── Features ────────────────────────────────── */
    .lp-features {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: .6rem .5rem;
    }
    .lp-feat {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .78rem;
        color: rgba(255,255,255,.5);
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.08);
        padding: .3rem .75rem;
        border-radius: 50px;
    }
    .lp-feat i { font-size: .85rem; color: rgba(255,255,255,.4); }

    /* ── Footer ──────────────────────────────────── */
    .lp-footer {
        text-align: center;
        font-size: .78rem;
        color: rgba(255,255,255,.3);
        padding: 1.25rem;
        position: relative;
        z-index: 2;
    }

    /* ── Generic fallback ────────────────────────── */
    .lp-generic { justify-content: center; align-items: center; }
    .lp-generic-inner { text-align: center; position: relative; z-index: 2; padding: 2rem; }
</style>
