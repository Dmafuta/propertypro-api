@page "/{TenantSlug}/parking"
@page "/parking"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanAccessParking")]
@inject IParkingService ParkingSvc
@inject IEntranceService EntranceSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject GateContext GateCtx
@inject AuthenticationStateProvider AuthState

@using FacilityApp.Data.Models

<PageTitle>Parking — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-p-circle me-2 text-primary"></i>Parking</h4>
        <small class="text-muted">Manage vehicle entry, exit, and access tags</small>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <span class="badge bg-primary fs-6 px-3 py-2">
            <i class="bi bi-car-front me-1"></i>@_currentlyInside.Count inside
        </span>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <button class="nav-link @(_tab == "active" ? "active" : "")" @onclick='() => _tab = "active"'>
            <i class="bi bi-car-front me-1"></i>Active (@_currentlyInside.Count)
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_tab == "entry" ? "active" : "")" @onclick='() => _tab = "entry"'>
            <i class="bi bi-box-arrow-in-right me-1"></i>Log Entry
        </button>
    </li>
    <AuthorizeView Policy="CanManageParking">
        <Authorized>
            <li class="nav-item">
                <button class="nav-link @(_tab == "vehicles" ? "active" : "")" @onclick='() => _tab = "vehicles"'>
                    <i class="bi bi-car-front-fill me-1"></i>Vehicles &amp; Tags
                </button>
            </li>
        </Authorized>
    </AuthorizeView>
    <li class="nav-item">
        <button class="nav-link @(_tab == "history" ? "active" : "")" @onclick='() => _tab = "history"'>
            <i class="bi bi-clock-history me-1"></i>History
        </button>
    </li>
</ul>

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border spinner-border-sm me-2"></div>Loading…
    </div>
}
else
{
    <!-- ── ACTIVE ─────────────────────────────────────────────────── -->
    @if (_tab == "active")
    {
        @if (_currentlyInside.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-p-circle fs-1 d-block mb-2 opacity-25"></i>
                No vehicles currently inside.
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Plate</th>
                                    <th>Type</th>
                                    <th>Tag / Visitor</th>
                                    <th>Owner / Visitor</th>
                                    <th>Entry Gate</th>
                                    <th>Entered</th>
                                    <th class="text-end pe-3">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in _currentlyInside)
                                {
                                    <tr>
                                        <td class="ps-3 fw-semibold">@r.PlateNumber</td>
                                        <td>@((MarkupString)TypeBadge(r.Type))</td>
                                        <td>
                                            @if (r.VehicleTag is not null)
                                            {
                                                <span class="badge bg-success">@r.VehicleTag.TagNumber</span>
                                            }
                                            else if (r.Visit?.Visitor is not null)
                                            {
                                                <small class="text-muted">Visitor</small>
                                            }
                                            else
                                            {
                                                <small class="text-muted">—</small>
                                            }
                                        </td>
                                        <td>
                                            @if (r.Vehicle?.Owner is not null)
                                            {
                                                <div class="small fw-medium">@r.Vehicle.Owner.FullName</div>
                                            }
                                            else if (r.Visit?.Visitor is not null)
                                            {
                                                <div class="small fw-medium">@r.Visit.Visitor.FullName</div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td class="small text-muted">@(r.EntryEntrance?.Name ?? "—")</td>
                                        <td class="small text-muted">
                                            @r.EnteredAt.ToLocalTime().ToString("MMM d, h:mm tt")
                                        </td>
                                        <td class="text-end pe-3">
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => LogExitAsync(r.Id)"
                                                    disabled="@_busy">
                                                <i class="bi bi-box-arrow-right me-1"></i>Exit
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }

    <!-- ── LOG ENTRY ───────────────────────────────────────────────── -->
    @if (_tab == "entry")
    {
        <div class="row g-4">
            <!-- Tag lookup -->
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="mb-0 fw-semibold">
                            <i class="bi bi-tag me-2 text-success"></i>Resident — Tag Scan
                        </h6>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">Enter the tag number from the resident's windscreen sticker.</p>
                        <div class="input-group mb-3">
                            <span class="input-group-text"><i class="bi bi-tag"></i></span>
                            <input class="form-control text-uppercase"
                                   placeholder="TAG-0001"
                                   @bind="_tagInput"
                                   @bind:event="oninput"
                                   @onkeydown="TagInputKeyDown" />
                            <button class="btn btn-success" @onclick="LookupTagAsync" disabled="@_busy">
                                Lookup
                            </button>
                        </div>

                        @if (_tagLookupResult is not null)
                        {
                            <div class="alert @(_tagLookupResult.Status == TagStatus.Active ? "alert-success" : "alert-danger") mb-3">
                                <div class="fw-semibold">@_tagLookupResult.TagNumber — @_tagLookupResult.Status</div>
                                <div class="small">@_tagLookupResult.Vehicle.Make @_tagLookupResult.Vehicle.Model · @_tagLookupResult.Vehicle.PlateNumber</div>
                                <div class="small">Owner: @_tagLookupResult.Vehicle.Owner.FullName</div>
                                @if (_tagLookupResult.ExpiresAt.HasValue)
                                {
                                    <div class="small">Expires: @_tagLookupResult.ExpiresAt.Value.ToLocalTime().ToString("MMM d, yyyy")</div>
                                }
                            </div>

                            @if (_tagLookupResult.Status == TagStatus.Active)
                            {
                                <button class="btn btn-success w-100" @onclick="LogTagEntryAsync" disabled="@_busy">
                                    @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Log Entry
                                </button>
                            }
                        }

                        @if (!string.IsNullOrEmpty(_tagError))
                        {
                            <div class="alert alert-danger mt-2 mb-0">@_tagError</div>
                        }
                        @if (!string.IsNullOrEmpty(_tagSuccess))
                        {
                            <div class="alert alert-success mt-2 mb-0">@_tagSuccess</div>
                        }
                    </div>
                </div>
            </div>

            <!-- Visitor / manual entry -->
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="mb-0 fw-semibold">
                            <i class="bi bi-person-badge me-2 text-primary"></i>Visitor / Walk-in
                        </h6>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">Manually log a visitor vehicle or unregistered vehicle.</p>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Plate Number <span class="text-danger">*</span></label>
                            <input class="form-control text-uppercase" placeholder="e.g. ABC 123" @bind="_visitorPlate" maxlength="20" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Notes <span class="text-muted fw-normal">(optional)</span></label>
                            <input class="form-control" placeholder="Visitor name, purpose, etc." @bind="_visitorNotes" />
                        </div>
                        @if (!string.IsNullOrEmpty(_visitorError))
                        {
                            <div class="alert alert-danger mb-2">@_visitorError</div>
                        }
                        @if (!string.IsNullOrEmpty(_visitorSuccess))
                        {
                            <div class="alert alert-success mb-2">@_visitorSuccess</div>
                        }
                        <button class="btn btn-primary w-100" @onclick="LogVisitorEntryAsync" disabled="@_busy">
                            @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="bi bi-box-arrow-in-right me-1"></i>Log Entry
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- ── VEHICLES & TAGS (Admin/Manager) ────────────────────────── -->
    @if (_tab == "vehicles")
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <input class="form-control form-control-sm" style="max-width:280px;"
                   placeholder="Search plate, owner…"
                   @bind="_vehicleSearch" @bind:event="oninput" />
        </div>

        @if (_vehicles.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-car-front fs-1 d-block mb-2 opacity-25"></i>
                No registered resident vehicles.
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Plate</th>
                                    <th>Vehicle</th>
                                    <th>Owner</th>
                                    <th class="text-center">Tag</th>
                                    <th class="text-center">Tag Status</th>
                                    <th>Expires</th>
                                    <th class="text-end pe-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var v in FilteredVehicles)
                                {
                                    <tr>
                                        <td class="ps-3 fw-semibold">@v.PlateNumber</td>
                                        <td class="small">@v.Make @v.Model <span class="text-muted">· @v.Colour</span></td>
                                        <td class="small">@v.Owner.FullName</td>
                                        <td class="text-center">
                                            @if (v.Tag is not null)
                                            {
                                                <span class="badge bg-light text-dark border fw-semibold">@v.Tag.TagNumber</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (v.Tag is not null)
                                            {
                                                @((MarkupString)TagStatusBadge(v.Tag.Status))
                                            }
                                        </td>
                                        <td class="small text-muted">
                                            @(v.Tag?.ExpiresAt?.ToLocalTime().ToString("MMM d, yyyy") ?? "—")
                                        </td>
                                        <td class="text-end pe-3">
                                            @if (v.Tag is null)
                                            {
                                                <button class="btn btn-sm btn-success"
                                                        @onclick="() => OpenIssueTag(v)"
                                                        title="Issue tag">
                                                    <i class="bi bi-tag me-1"></i>Issue Tag
                                                </button>
                                            }
                                            else
                                            {
                                                <div class="btn-group btn-group-sm">
                                                    @if (v.Tag.Status == TagStatus.Active)
                                                    {
                                                        <button class="btn btn-outline-warning"
                                                                @onclick="() => SetTagStatus(v.Tag.Id, TagStatus.Suspended)"
                                                                title="Suspend">
                                                            <i class="bi bi-pause-circle"></i>
                                                        </button>
                                                    }
                                                    else if (v.Tag.Status == TagStatus.Suspended)
                                                    {
                                                        <button class="btn btn-outline-success"
                                                                @onclick="() => SetTagStatus(v.Tag.Id, TagStatus.Active)"
                                                                title="Reactivate">
                                                            <i class="bi bi-play-circle"></i>
                                                        </button>
                                                    }
                                                    <button class="btn btn-outline-danger"
                                                            @onclick="() => SetTagStatus(v.Tag.Id, TagStatus.Revoked)"
                                                            title="Revoke">
                                                        <i class="bi bi-x-circle"></i>
                                                    </button>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }

    <!-- ── HISTORY ─────────────────────────────────────────────────── -->
    @if (_tab == "history")
    {
        <div class="d-flex gap-2 mb-3 flex-wrap align-items-end">
            <div>
                <label class="form-label small mb-1">From</label>
                <input type="date" class="form-control form-control-sm"
                       @bind="_histFrom" style="width:160px;" />
            </div>
            <div>
                <label class="form-label small mb-1">To</label>
                <input type="date" class="form-control form-control-sm"
                       @bind="_histTo" style="width:160px;" />
            </div>
            <button class="btn btn-sm btn-primary" @onclick="LoadHistoryAsync" disabled="@_busy">
                <i class="bi bi-search me-1"></i>Filter
            </button>
        </div>

        @if (_history.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-clock-history fs-1 d-block mb-2 opacity-25"></i>
                No parking records for this period.
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Plate</th>
                                    <th>Type</th>
                                    <th>Tag</th>
                                    <th>Owner / Visitor</th>
                                    <th>Entry</th>
                                    <th>Exit</th>
                                    <th>Duration</th>
                                    <th class="pe-3">Gate</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in _history)
                                {
                                    <tr>
                                        <td class="ps-3 fw-semibold">@r.PlateNumber</td>
                                        <td>@((MarkupString)TypeBadge(r.Type))</td>
                                        <td>
                                            @if (r.VehicleTag is not null)
                                            {
                                                <span class="badge bg-light text-dark border">@r.VehicleTag.TagNumber</span>
                                            }
                                            else { <span class="text-muted small">—</span> }
                                        </td>
                                        <td class="small">
                                            @(r.Vehicle?.Owner?.FullName ?? r.Visit?.Visitor?.FullName ?? "—")
                                        </td>
                                        <td class="small text-muted">@r.EnteredAt.ToLocalTime().ToString("MMM d, h:mm tt")</td>
                                        <td class="small text-muted">
                                            @(r.ExitedAt.HasValue ? r.ExitedAt.Value.ToLocalTime().ToString("MMM d, h:mm tt") : "—")
                                        </td>
                                        <td class="small text-muted">
                                            @if (r.ExitedAt.HasValue)
                                            {
                                                var dur = r.ExitedAt.Value - r.EnteredAt;
                                                @($"{(int)dur.TotalHours}h {dur.Minutes}m")
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Inside</span>
                                            }
                                        </td>
                                        <td class="small pe-3 text-muted">@(r.EntryEntrance?.Name ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="px-3 py-2 border-top">
                        <small class="text-muted">@_history.Count record@(_history.Count == 1 ? "" : "s")</small>
                    </div>
                </div>
            </div>
        }
    }
}

<!-- Issue Tag Modal -->
@if (_issueTagTarget is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);" @onclick="CloseIssueTag">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0">
                    <h6 class="modal-title fw-semibold"><i class="bi bi-tag me-2 text-success"></i>Issue Access Tag</h6>
                    <button type="button" class="btn-close" @onclick="CloseIssueTag"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-light border mb-3">
                        <div class="fw-medium">@_issueTagTarget.PlateNumber</div>
                        <div class="small text-muted">@_issueTagTarget.Make @_issueTagTarget.Model · @_issueTagTarget.Colour</div>
                        <div class="small text-muted">Owner: @_issueTagTarget.Owner.FullName</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Expiry Date <span class="text-muted fw-normal">(leave blank for no expiry)</span></label>
                        <input type="date" class="form-control" @bind="_issueExpiry" />
                    </div>
                    <div class="mb-1">
                        <label class="form-label fw-medium">Notes <span class="text-muted fw-normal">(optional)</span></label>
                        <input class="form-control" placeholder="Any notes about this tag" @bind="_issueNotes" />
                    </div>
                    @if (!string.IsNullOrEmpty(_issueError))
                    {
                        <div class="alert alert-danger mt-3 mb-0">@_issueError</div>
                    }
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-outline-secondary" @onclick="CloseIssueTag" disabled="@_busy">Cancel</button>
                    <button class="btn btn-success" @onclick="ConfirmIssueTagAsync" disabled="@_busy">
                        @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-tag me-1"></i>Issue Tag
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_toast is not null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100;">
        <div class="toast show align-items-center text-bg-@_toastType border-0 shadow">
            <div class="d-flex">
                <div class="toast-body">@_toast</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => _toast = null"></button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private string _tab = "active";
    private bool _loading = true;
    private bool _busy;
    private string _userId = "";

    private List<ParkingRecord> _currentlyInside = [];
    private List<Vehicle> _vehicles = [];
    private List<ParkingRecord> _history = [];
    private string _vehicleSearch = "";

    // Tag entry
    private string _tagInput = "";
    private VehicleTag? _tagLookupResult;
    private string _tagError = "";
    private string _tagSuccess = "";

    // Visitor entry
    private string _visitorPlate = "";
    private string _visitorNotes = "";
    private string _visitorError = "";
    private string _visitorSuccess = "";

    // Issue tag modal
    private Vehicle? _issueTagTarget;
    private DateTime? _issueExpiry;
    private string _issueNotes = "";
    private string _issueError = "";

    // History filter
    private DateOnly _histFrom = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _histTo   = DateOnly.FromDateTime(DateTime.Today);

    private string? _toast;
    private string _toastType = "success";

    private List<Vehicle> FilteredVehicles
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_vehicleSearch)) return _vehicles;
            var s = _vehicleSearch.Trim().ToLower();
            return _vehicles.Where(v =>
                v.PlateNumber.ToLower().Contains(s) ||
                v.Make.ToLower().Contains(s) ||
                v.Model.ToLower().Contains(s) ||
                v.Owner.FullName.ToLower().Contains(s)).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        var auth = await AuthState.GetAuthenticationStateAsync();
        _userId  = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        _currentlyInside = await ParkingSvc.GetCurrentlyInsideAsync();
        _vehicles        = await ParkingSvc.GetAllVehiclesAsync();
        _loading         = false;
    }

    // ── Active tab ─────────────────────────────────────────────────────────────

    private async Task LogExitAsync(Guid recordId)
    {
        _busy = true;
        try
        {
            await ParkingSvc.LogExitAsync(recordId, _userId, GateCtx.IsSelected ? GateCtx.EntranceId : null);
            _currentlyInside = await ParkingSvc.GetCurrentlyInsideAsync();
            ShowToast("Exit logged.", "success");
        }
        catch (Exception ex) { ShowToast(ex.Message, "danger"); }
        finally { _busy = false; }
    }

    // ── Log Entry tab ─────────────────────────────────────────────────────────

    private async Task TagInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LookupTagAsync();
    }

    private async Task LookupTagAsync()
    {
        _tagError = ""; _tagSuccess = ""; _tagLookupResult = null;
        if (string.IsNullOrWhiteSpace(_tagInput)) { _tagError = "Enter a tag number."; return; }
        _tagLookupResult = await ParkingSvc.LookupTagAsync(_tagInput.Trim().ToUpperInvariant());
        if (_tagLookupResult is null) _tagError = $"Tag '{_tagInput.Trim().ToUpperInvariant()}' not found.";
    }

    private async Task LogTagEntryAsync()
    {
        _tagError = ""; _tagSuccess = "";
        _busy = true;
        try
        {
            await ParkingSvc.LogEntryByTagAsync(
                _tagInput.Trim().ToUpperInvariant(),
                _userId,
                GateCtx.IsSelected ? GateCtx.EntranceId : null);
            _currentlyInside = await ParkingSvc.GetCurrentlyInsideAsync();
            _tagInput = ""; _tagLookupResult = null;
            _tagSuccess = "Entry logged successfully.";
            ShowToast("Entry logged.", "success");
        }
        catch (Exception ex) { _tagError = ex.Message; }
        finally { _busy = false; }
    }

    private async Task LogVisitorEntryAsync()
    {
        _visitorError = ""; _visitorSuccess = "";
        if (string.IsNullOrWhiteSpace(_visitorPlate)) { _visitorError = "Plate number is required."; return; }
        _busy = true;
        try
        {
            await ParkingSvc.LogVisitorEntryAsync(
                _visitorPlate, _userId, null,
                GateCtx.IsSelected ? GateCtx.EntranceId : null,
                _visitorNotes);
            _currentlyInside = await ParkingSvc.GetCurrentlyInsideAsync();
            _visitorPlate = ""; _visitorNotes = "";
            _visitorSuccess = "Visitor entry logged.";
            ShowToast("Visitor entry logged.", "success");
        }
        catch (Exception ex) { _visitorError = ex.Message; }
        finally { _busy = false; }
    }

    // ── Vehicles & Tags tab ───────────────────────────────────────────────────

    private void OpenIssueTag(Vehicle v)
    {
        _issueTagTarget = v;
        _issueExpiry    = null;
        _issueNotes     = "";
        _issueError     = "";
    }

    private void CloseIssueTag() => _issueTagTarget = null;

    private async Task ConfirmIssueTagAsync()
    {
        if (_issueTagTarget is null) return;
        _busy = true;
        try
        {
            await ParkingSvc.IssueTagAsync(
                _issueTagTarget.Id, _userId,
                _issueExpiry.HasValue ? _issueExpiry.Value.ToUniversalTime() : null,
                _issueNotes);
            _vehicles = await ParkingSvc.GetAllVehiclesAsync();
            CloseIssueTag();
            ShowToast("Tag issued successfully.", "success");
        }
        catch (Exception ex) { _issueError = ex.Message; }
        finally { _busy = false; }
    }

    private async Task SetTagStatus(Guid tagId, TagStatus status)
    {
        _busy = true;
        try
        {
            await ParkingSvc.UpdateTagStatusAsync(tagId, status);
            _vehicles = await ParkingSvc.GetAllVehiclesAsync();
            ShowToast($"Tag {status}.", status == TagStatus.Active ? "success" : "warning");
        }
        catch (Exception ex) { ShowToast(ex.Message, "danger"); }
        finally { _busy = false; }
    }

    // ── History tab ────────────────────────────────────────────────────────────

    private async Task LoadHistoryAsync()
    {
        _busy = true;
        _history = await ParkingSvc.GetRecordsAsync(_histFrom, _histTo);
        _busy = false;
    }

    // ── Helpers ────────────────────────────────────────────────────────────────

    private void ShowToast(string message, string type)
    {
        _toast     = message;
        _toastType = type;
        _ = Task.Delay(4000).ContinueWith(_ => { _toast = null; InvokeAsync(StateHasChanged); });
    }

    private static string TypeBadge(ParkingRecordType t) => t switch
    {
        ParkingRecordType.Resident => "<span class=\"badge bg-success\">Resident</span>",
        ParkingRecordType.Visitor  => "<span class=\"badge bg-info text-dark\">Visitor</span>",
        _                          => "<span class=\"badge bg-secondary\">Unknown</span>"
    };

    private static string TagStatusBadge(TagStatus s) => s switch
    {
        TagStatus.Active    => "<span class=\"badge bg-success\">Active</span>",
        TagStatus.Suspended => "<span class=\"badge bg-warning text-dark\">Suspended</span>",
        TagStatus.Revoked   => "<span class=\"badge bg-danger\">Revoked</span>",
        TagStatus.Expired   => "<span class=\"badge bg-secondary\">Expired</span>",
        _                   => "<span class=\"badge bg-light text-dark\">—</span>"
    };
}
