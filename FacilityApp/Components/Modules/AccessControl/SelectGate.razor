@page "/{TenantSlug}/select-gate"
@page "/select-gate"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanCheckInVisitors")]
@inject IEntranceService EntranceSvc
@inject GateContext GateCtx
@inject TenantContext TenantCtx
@inject ITenantService TenantSvc
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

@using FacilityApp.Data.Models

<PageTitle>Select Gate — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-center align-items-center py-5">
    <div style="max-width:640px;width:100%;">
        <div class="text-center mb-5">
            <div class="mb-3" style="font-size:3.5rem;line-height:1;">
                <i class="bi bi-door-open text-primary"></i>
            </div>
            <h3 class="fw-bold mb-1">Select Your Gate</h3>
            <p class="text-muted mb-0">Choose the entrance you are working at for this session.</p>
        </div>

        @if (_loading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary"></div>
            </div>
        }
        else if (_entrances.Count == 0)
        {
            <div class="alert alert-warning text-center">
                <i class="bi bi-exclamation-triangle me-2"></i>
                No entrances have been configured yet.
                <AuthorizeView Roles="Admin">
                    <br />
                    <a href="@($"{TenantCtx.RouteBase}/admin/entrances")" class="alert-link fw-semibold">
                        Go to Entrances to add one
                    </a>
                </AuthorizeView>
            </div>
        }
        else
        {
            <div class="row g-3 mb-4">
                @foreach (var entrance in _entrances)
                {
                    var e = entrance;
                    <div class="col-sm-6">
                        <button class="btn w-100 p-4 h-100 text-start @(_selected == e.Id ? "btn-primary" : "btn-outline-primary")"
                                style="border-width:2px;"
                                @onclick="() => SelectAsync(e.Id, e.Name)"
                                disabled="@_busy">
                            <div class="d-flex align-items-center gap-3">
                                <i class="bi bi-door-open fs-2 flex-shrink-0"></i>
                                <div>
                                    <div class="fw-semibold fs-5">@e.Name</div>
                                    @if (!string.IsNullOrEmpty(e.Description))
                                    {
                                        <small class="@(_selected == e.Id ? "text-white-50" : "text-muted")">@e.Description</small>
                                    }
                                </div>
                            </div>
                        </button>
                    </div>
                }
            </div>
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }
    </div>
</div>

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private List<Entrance> _entrances = [];
    private bool _loading = true;
    private bool _busy;
    private Guid? _selected;
    private string _error = "";

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }
        _entrances = await EntranceSvc.GetActiveAsync();
        _loading   = false;
    }

    private async Task SelectAsync(Guid entranceId, string entranceName)
    {
        _busy     = true;
        _selected = entranceId;
        _error    = "";
        try
        {
            var auth   = await AuthState.GetAuthenticationStateAsync();
            var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (userId is not null)
                await EntranceSvc.SetCurrentEntranceAsync(userId, entranceId);

            GateCtx.EntranceId   = entranceId;
            GateCtx.EntranceName = entranceName;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _busy  = false;
            return;
        }

        Nav.NavigateTo($"{TenantCtx.RouteBase}/dashboard");
    }
}
