@page "/{TenantSlug}/visitors/{VisitId:guid}"
@page "/visitors/{VisitId:guid}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanCheckInVisitors")]
@inject IVisitorService VisitorSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject NavigationManager Nav

@using FacilityApp.Data.Models

<PageTitle>Visit Detail — @TenantCtx.TenantName</PageTitle>

@if (_visit is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="@(TenantCtx.RouteBase)/visitors" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
        <div class="flex-grow-1">
            <h4 class="mb-0 fw-bold"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Visit Detail</h4>
            <small class="text-muted">ID: @_visit.Id.ToString()[..8].ToUpper()</small>
        </div>
        <a href="@(TenantCtx.RouteBase)/visitors/@_visit.Id/badge" target="_blank"
           class="btn btn-sm btn-outline-primary">
            <i class="bi bi-printer me-1"></i>Print Badge
        </a>
    </div>

    <div class="row g-4">

        <!-- Visitor info -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-person me-2 text-primary"></i>Visitor</h6>
                </div>
                <div class="card-body text-center pt-4">
                    @if (!string.IsNullOrEmpty(_visit.Visitor.PhotoUrl))
                    {
                        <img src="@_visit.Visitor.PhotoUrl" alt="@_visit.Visitor.FullName"
                             style="width:90px;height:90px;object-fit:cover;border-radius:50%;border:3px solid #1b6ec2;" class="mb-3" />
                    }
                    else
                    {
                        <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10 text-primary fw-bold"
                             style="width:90px;height:90px;font-size:2rem;">
                            @(_visit.Visitor.FullName.Length > 0 ? _visit.Visitor.FullName[0].ToString().ToUpper() : "?")
                        </div>
                    }
                    <div class="fw-bold fs-5">@_visit.Visitor.FullName</div>
                    @if (!string.IsNullOrEmpty(_visit.Visitor.Company))
                    {
                        <div class="text-muted small">@_visit.Visitor.Company</div>
                    }
                </div>
                <div class="card-body border-top pt-3">
                    <dl class="row small mb-0">
                        <dt class="col-4 text-muted fw-normal">Email</dt>
                        <dd class="col-8">@_visit.Visitor.Email</dd>
                        <dt class="col-4 text-muted fw-normal">Phone</dt>
                        <dd class="col-8">@_visit.Visitor.Phone</dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Visit info -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-calendar-event me-2 text-primary"></i>Visit Details</h6>
                </div>
                <div class="card-body">
                    <dl class="row small mb-0">
                        <dt class="col-sm-3 text-muted fw-normal">Status</dt>
                        <dd class="col-sm-9">@((MarkupString)StatusBadge(_visit.Status))</dd>

                        <dt class="col-sm-3 text-muted fw-normal">Purpose</dt>
                        <dd class="col-sm-9">@_visit.Purpose</dd>

                        <dt class="col-sm-3 text-muted fw-normal">Host</dt>
                        <dd class="col-sm-9">@(_visit.Host?.FullName ?? "—")</dd>

                        <dt class="col-sm-3 text-muted fw-normal">Scheduled</dt>
                        <dd class="col-sm-9">@_visit.ScheduledAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</dd>

                        <dt class="col-sm-3 text-muted fw-normal">Checked In</dt>
                        <dd class="col-sm-9">
                            @if (_visit.CheckedInAt.HasValue)
                            {
                                @_visit.CheckedInAt.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                            }
                            else { <text>—</text> }
                        </dd>

                        <dt class="col-sm-3 text-muted fw-normal">Entry Gate</dt>
                        <dd class="col-sm-9">
                            @if (_visit.EntryEntrance is not null)
                            {
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 fw-normal">
                                    <i class="bi bi-door-open me-1"></i>@_visit.EntryEntrance.Name
                                </span>
                            }
                            else { <span class="text-muted">—</span> }
                        </dd>

                        <dt class="col-sm-3 text-muted fw-normal">Checked Out</dt>
                        <dd class="col-sm-9">
                            @if (_visit.CheckedOutAt.HasValue)
                            {
                                @_visit.CheckedOutAt.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                            }
                            else { <text>—</text> }
                        </dd>

                        <dt class="col-sm-3 text-muted fw-normal">Exit Gate</dt>
                        <dd class="col-sm-9">
                            @if (_visit.ExitEntrance is not null)
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 fw-normal">
                                    <i class="bi bi-door-open me-1"></i>@_visit.ExitEntrance.Name
                                </span>
                            }
                            else { <span class="text-muted">—</span> }
                        </dd>

                        @if (!string.IsNullOrEmpty(_visit.Notes))
                        {
                            <dt class="col-sm-3 text-muted fw-normal">Notes</dt>
                            <dd class="col-sm-9">@_visit.Notes</dd>
                        }
                    </dl>
                </div>
            </div>
        </div>

    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";
    [Parameter] public Guid VisitId { get; set; }

    private Visit? _visit;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        var (items, _) = await VisitorSvc.GetVisitsAsync("all", null, 1, int.MaxValue);
        _visit = items.FirstOrDefault(v => v.Id == VisitId);
    }

    private static string StatusBadge(VisitStatus s) => s switch
    {
        VisitStatus.Scheduled  => "<span class=\"badge bg-primary\">Scheduled</span>",
        VisitStatus.CheckedIn  => "<span class=\"badge bg-success\">Checked In</span>",
        VisitStatus.CheckedOut => "<span class=\"badge bg-secondary\">Checked Out</span>",
        VisitStatus.Cancelled  => "<span class=\"badge bg-danger\">Cancelled</span>",
        VisitStatus.NoShow     => "<span class=\"badge bg-warning text-dark\">No Show</span>",
        _                      => "<span class=\"badge bg-light text-dark\">Unknown</span>"
    };
}
