@page "/superadmin/dashboard"
@rendermode InteractiveServer
@layout SuperAdminLayout
@attribute [Authorize(Roles = "SuperAdmin")]
@inject AppDbContext Db

@using FacilityApp.Data.Models
@using Microsoft.EntityFrameworkCore

<PageTitle>Platform Dashboard — FacilityApp</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-speedometer2 me-2 text-primary"></i>Platform Dashboard</h4>
        <small class="text-muted">Overview of all facilities on this installation</small>
    </div>
    <a href="/superadmin/tenants/create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Tenant
    </a>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_error is not null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@_error</div>
}
else
{
    <!-- Stats row -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 bg-primary bg-opacity-10">
                        <i class="bi bi-buildings fs-4 text-primary"></i>
                    </div>
                    <div>
                        <div class="fs-3 fw-bold">@_totalTenants</div>
                        <div class="text-muted small">Total Tenants</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 bg-success bg-opacity-10">
                        <i class="bi bi-check-circle fs-4 text-success"></i>
                    </div>
                    <div>
                        <div class="fs-3 fw-bold">@_activeTenants</div>
                        <div class="text-muted small">Active</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 bg-warning bg-opacity-10">
                        <i class="bi bi-star-fill fs-4 text-warning"></i>
                    </div>
                    <div>
                        <div class="fs-3 fw-bold">@_professionalTenants</div>
                        <div class="text-muted small">Professional</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 bg-info bg-opacity-10">
                        <i class="bi bi-people fs-4 text-info"></i>
                    </div>
                    <div>
                        <div class="fs-3 fw-bold">@_totalUsers</div>
                        <div class="text-muted small">Total Staff Users</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Recent tenants -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2 text-primary"></i>Recent Tenants</h6>
                    <a href="/superadmin/tenants" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Name</th>
                                <th>Slug</th>
                                <th>Plan</th>
                                <th>Status</th>
                                <th class="pe-3">Created</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in _recentTenants)
                            {
                                <tr>
                                    <td class="ps-3 fw-semibold">@t.Name</td>
                                    <td><code class="small">@t.Slug</code></td>
                                    <td>
                                        @if (t.Plan == TenantPlan.Professional)
                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-star-fill me-1"></i>Pro</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Starter</span>
                                        }
                                    </td>
                                    <td>
                                        @if (t.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-muted small pe-3">@t.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Quick actions + plan breakdown -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-lightning-charge me-2 text-primary"></i>Quick Actions</h6>
                </div>
                <div class="card-body d-grid gap-2">
                    <a href="/superadmin/tenants/create" class="btn btn-outline-primary text-start">
                        <i class="bi bi-plus-circle me-2"></i>Create New Tenant
                    </a>
                    <a href="/superadmin/tenants" class="btn btn-outline-secondary text-start">
                        <i class="bi bi-grid me-2"></i>Manage All Tenants
                    </a>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-pie-chart me-2 text-primary"></i>Plan Breakdown</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small">Professional</span>
                        <span class="fw-semibold">@_professionalTenants</span>
                    </div>
                    <div class="progress mb-3" style="height:8px;">
                        <div class="progress-bar bg-warning" style="width:@(_totalTenants > 0 ? (_professionalTenants * 100 / _totalTenants) : 0)%"></div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small">Starter</span>
                        <span class="fw-semibold">@_starterTenants</span>
                    </div>
                    <div class="progress" style="height:8px;">
                        <div class="progress-bar bg-secondary" style="width:@(_totalTenants > 0 ? (_starterTenants * 100 / _totalTenants) : 0)%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private int _totalTenants;
    private int _activeTenants;
    private int _professionalTenants;
    private int _starterTenants;
    private int _totalUsers;
    private List<Tenant> _recentTenants = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tenants = await Db.Tenants
                .IgnoreQueryFilters()
                .Where(t => !t.IsSystem)
                .ToListAsync();

            _totalTenants        = tenants.Count;
            _activeTenants       = tenants.Count(t => t.IsActive);
            _professionalTenants = tenants.Count(t => t.Plan == TenantPlan.Professional);
            _starterTenants      = tenants.Count(t => t.Plan == TenantPlan.Starter);
            _recentTenants       = tenants.OrderByDescending(t => t.CreatedAt).Take(5).ToList();

            _totalUsers = await Db.Users
                .IgnoreQueryFilters()
                .Where(u => tenants.Select(t => t.Id).Contains(u.TenantId) && u.UserType == UserType.Staff)
                .CountAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
