@page "/superadmin/tenants/create"
@rendermode InteractiveServer
@layout SuperAdminLayout
@attribute [Authorize(Roles = "SuperAdmin")]
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav
@using FacilityApp.Data.Models

<PageTitle>Create Tenant — Super Admin</PageTitle>

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/superadmin/tenants" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <h4 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>Create New Tenant</h4>
</div>

<div class="row g-4">
    <div class="col-lg-6">

        @if (_done)
        {
            <div class="alert alert-success">
                <h5 class="fw-bold"><i class="bi bi-check-circle me-2"></i>Tenant Created</h5>
                <p class="mb-1">Facility <strong>@_form.FacilityName</strong> is ready.</p>
                <p class="mb-3">Admin login: <strong>@_form.AdminEmail</strong></p>
                <div class="d-flex gap-2">
                    <a href="/@_createdSlug/login" target="_blank" class="btn btn-success btn-sm">
                        <i class="bi bi-box-arrow-up-right me-1"></i>Open Portal
                    </a>
                    <a href="/superadmin/tenants" class="btn btn-outline-secondary btn-sm">Back to List</a>
                </div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold">Facility Details</h6>
                </div>
                <div class="card-body">
                    <EditForm Model="_form" OnValidSubmit="HandleAsync">
                        <DataAnnotationsValidator />

                        @if (_error is not null)
                        {
                            <div class="alert alert-danger py-2 small">@_error</div>
                        }

                        <p class="text-muted small fw-semibold text-uppercase mb-2" style="letter-spacing:.06em;">Facility</p>

                        <div class="mb-3">
                            <label class="form-label fw-medium small">Facility Name <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="_form.FacilityName" placeholder="Sunrise Towers" />
                            <ValidationMessage For="() => _form.FacilityName" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium small">URL Slug <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="_form.Slug" placeholder="sunrise-towers" />
                            <div class="form-text">Lowercase letters, numbers and hyphens only.</div>
                            <ValidationMessage For="() => _form.Slug" class="text-danger small" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-medium small">Plan</label>
                            <select class="form-select" @bind="_form.Plan">
                                <option value="@TenantPlan.Starter">Starter — shared domain (yourapp.com/slug/...)</option>
                                <option value="@TenantPlan.Professional">Professional — custom domain eligible</option>
                            </select>
                        </div>

                        <hr class="my-3" />
                        <p class="text-muted small fw-semibold text-uppercase mb-2" style="letter-spacing:.06em;">Admin Account</p>

                        <div class="mb-3">
                            <label class="form-label fw-medium small">Full Name <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="_form.AdminName" placeholder="Jane Smith" />
                            <ValidationMessage For="() => _form.AdminName" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium small">Email <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="_form.AdminEmail" placeholder="admin@facility.com" />
                            <ValidationMessage For="() => _form.AdminEmail" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium small">Password <span class="text-danger">*</span></label>
                            <InputText type="password" class="form-control" @bind-Value="_form.Password" placeholder="Min. 8 chars, 1 digit" />
                            <ValidationMessage For="() => _form.Password" class="text-danger small" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-medium small">Confirm Password <span class="text-danger">*</span></label>
                            <InputText type="password" class="form-control" @bind-Value="_form.ConfirmPassword" />
                            <ValidationMessage For="() => _form.ConfirmPassword" class="text-danger small" />
                        </div>

                        <button type="submit" class="btn btn-primary" disabled="@_busy">
                            @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Create Tenant &amp; Admin
                        </button>
                    </EditForm>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-5">
        <div class="card border-0 bg-light">
            <div class="card-body py-4">
                <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>What this does</h6>
                <ul class="list-unstyled small text-muted mb-0">
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Creates a new isolated tenant (facility).</li>
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Creates an Admin user account for that tenant.</li>
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>The tenant portal becomes immediately accessible at <code>/{slug}/login</code>.</li>
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Each tenant's data is fully isolated from others.</li>
                    <li><i class="bi bi-star text-warning me-2"></i><strong>Professional</strong> plan unlocks custom domain (e.g. <code>facility.estate</code>). Plan can be changed anytime from the Tenants list.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@code {
    private CreateForm _form = new();
    private bool _busy;
    private bool _done;
    private string? _error;
    private string _createdSlug = "";

    private async Task HandleAsync()
    {
        _busy = true; _error = null;
        try
        {
            var slug = _form.Slug.Trim().ToLower();

            if (await Db.Tenants.IgnoreQueryFilters().AnyAsync(t => t.Slug == slug))
            {
                _error = "A tenant with that slug already exists.";
                return;
            }

            var tenant = new Tenant
            {
                Id        = Guid.NewGuid(),
                Name      = _form.FacilityName.Trim(),
                Slug      = slug,
                Plan      = _form.Plan,
                IsActive  = true,
                CreatedAt = DateTime.UtcNow
            };
            Db.Tenants.Add(tenant);
            await Db.SaveChangesAsync();

            var user = new ApplicationUser
            {
                UserName = _form.AdminEmail,
                Email    = _form.AdminEmail,
                FullName = _form.AdminName.Trim(),
                TenantId = tenant.Id,
                UserType = UserType.Staff
            };

            var result = await UserManager.CreateAsync(user, _form.Password);
            if (!result.Succeeded)
            {
                Db.Tenants.Remove(tenant);
                await Db.SaveChangesAsync();
                _error = string.Join(" ", result.Errors.Select(e => e.Description));
                return;
            }

            await UserManager.AddToRoleAsync(user, Program.RoleAdmin);
            _createdSlug = slug;
            _done        = true;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private sealed class CreateForm
    {
        [Required(ErrorMessage = "Facility name is required.")]
        [MaxLength(100)]
        public string FacilityName { get; set; } = "";

        public TenantPlan Plan { get; set; } = TenantPlan.Starter;

        [Required(ErrorMessage = "Slug is required.")]
        [RegularExpression(@"^[a-z0-9\-]+$", ErrorMessage = "Lowercase letters, numbers and hyphens only.")]
        [MaxLength(60)]
        public string Slug { get; set; } = "";

        [Required(ErrorMessage = "Admin name is required.")]
        [MaxLength(100)]
        public string AdminName { get; set; } = "";

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress]
        public string AdminEmail { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Minimum 8 characters.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
