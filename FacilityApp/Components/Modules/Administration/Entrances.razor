@page "/{TenantSlug}/admin/entrances"
@page "/admin/entrances"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanManageUsers")]
@inject IEntranceService EntranceSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx

@using FacilityApp.Data.Models

<PageTitle>Entrances — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-door-open me-2 text-primary"></i>Entrances</h4>
        <small class="text-muted">Manage gates and entrances for @TenantCtx.TenantName</small>
    </div>
    @if (!_showForm)
    {
        <button class="btn btn-primary" @onclick="() => _showForm = true">
            <i class="bi bi-plus-lg me-1"></i>Add Entrance
        </button>
    }
</div>

@if (_showForm)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3">
            <h6 class="mb-0 fw-semibold">
                <i class="bi bi-pencil-square me-2 text-primary"></i>
                @(_editId.HasValue ? "Edit Entrance" : "New Entrance")
            </h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-medium">Name <span class="text-danger">*</span></label>
                    <input class="form-control" placeholder="e.g. Main Gate" @bind="_name" maxlength="100" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-medium">Description <span class="text-muted small">(optional)</span></label>
                    <input class="form-control" placeholder="e.g. Front entrance off Main Street" @bind="_description" maxlength="200" />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_formError))
            {
                <div class="alert alert-danger mt-3 mb-0">@_formError</div>
            }
        </div>
        <div class="card-footer bg-white border-top d-flex gap-2 justify-content-end">
            <button class="btn btn-outline-secondary" @onclick="CancelForm" disabled="@_busy">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_busy">
                @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                @(_editId.HasValue ? "Save Changes" : "Add Entrance")
            </button>
        </div>
    </div>
}

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border text-primary mb-2"></div>
        <p>Loading…</p>
    </div>
}
else if (_entrances.Count == 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-door-open fs-1 d-block mb-3 opacity-25"></i>
            <h5>No entrances configured</h5>
            <p class="mb-0 small">Add gates so staff can be assigned to a specific entrance.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Name</th>
                            <th>Description</th>
                            <th>Created</th>
                            <th class="text-center">Status</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in _entrances)
                        {
                            <tr class="@(e.IsActive ? "" : "opacity-50")">
                                <td class="ps-3 fw-medium">
                                    <i class="bi bi-door-open me-2 text-muted"></i>@e.Name
                                </td>
                                <td class="small text-muted">@(e.Description ?? "—")</td>
                                <td class="small text-muted">@e.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                                <td class="text-center">
                                    @if (e.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    <button class="btn btn-sm btn-outline-secondary me-1"
                                            @onclick="() => EditEntrance(e)"
                                            disabled="@_busy" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary me-1"
                                            @onclick="() => ToggleAsync(e.Id)"
                                            disabled="@_busy"
                                            title="@(e.IsActive ? "Deactivate" : "Activate")">
                                        <i class="bi @(e.IsActive ? "bi-eye-slash" : "bi-eye")"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => DeleteAsync(e.Id)"
                                            disabled="@_busy" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (_toast is not null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100;">
        <div class="toast show align-items-center text-bg-@_toastType border-0 shadow">
            <div class="d-flex">
                <div class="toast-body">@_toast</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => _toast = null"></button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private List<Entrance> _entrances = [];
    private bool _loading = true;
    private bool _busy;
    private bool _showForm;
    private Guid? _editId;
    private string _name = "";
    private string? _description;
    private string _formError = "";
    private string? _toast;
    private string _toastType = "success";

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading   = true;
        _entrances = await EntranceSvc.GetAllAsync();
        _loading   = false;
    }

    private async Task SaveAsync()
    {
        _formError = "";
        if (string.IsNullOrWhiteSpace(_name)) { _formError = "Name is required."; return; }
        _busy = true;
        try
        {
            if (_editId.HasValue)
                await EntranceSvc.UpdateAsync(_editId.Value, _name, _description);
            else
                await EntranceSvc.CreateAsync(_name, _description);
            CancelForm();
            await LoadAsync();
            ShowToast(_editId.HasValue ? "Entrance updated." : "Entrance added.", "success");
        }
        catch (Exception ex) { _formError = ex.Message; }
        finally { _busy = false; }
    }

    private void EditEntrance(Entrance e)
    {
        _editId      = e.Id;
        _name        = e.Name;
        _description = e.Description;
        _showForm    = true;
        _formError   = "";
    }

    private async Task ToggleAsync(Guid id)
    {
        _busy = true;
        try { await EntranceSvc.ToggleActiveAsync(id); await LoadAsync(); }
        catch (Exception ex) { ShowToast(ex.Message, "danger"); }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(Guid id)
    {
        _busy = true;
        try { await EntranceSvc.DeleteAsync(id); await LoadAsync(); ShowToast("Deleted.", "warning"); }
        catch (Exception ex) { ShowToast(ex.Message, "danger"); }
        finally { _busy = false; }
    }

    private void CancelForm()
    {
        _showForm    = false;
        _editId      = null;
        _name        = "";
        _description = null;
        _formError   = "";
    }

    private void ShowToast(string message, string type)
    {
        _toast     = message;
        _toastType = type;
        _ = Task.Delay(4000).ContinueWith(_ => { _toast = null; InvokeAsync(StateHasChanged); });
    }
}
