@page "/{TenantSlug}/dashboard"
@page "/dashboard"
@rendermode InteractiveServer
@attribute [Authorize]
@inject ITenantService TenantService
@inject TenantContext TenantCtx
@inject IDashboardService DashboardService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserMgr
@implements IDisposable

<PageTitle>Dashboard — @(TenantCtx.IsResolved ? TenantCtx.TenantName : TenantSlug)</PageTitle>

@if (loading)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
        <div class="text-center">
            <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;"></div>
            <p class="text-muted">Loading dashboard...</p>
        </div>
    </div>
}
else if (tenantNotFound)
{
    <div class="alert alert-danger mt-4">
        <h5 class="alert-heading"><i class="bi bi-exclamation-triangle me-2"></i>Facility Not Found</h5>
        <p class="mb-0">No active facility found for <code>@TenantSlug</code>. Please check the URL.</p>
    </div>
}
else
{
    <div class="dashboard-wrapper">

        <!-- Page Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="mb-0 fw-bold">
                    <i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard
                </h4>
                <small class="text-muted">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</small>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted small">
                    <i class="bi bi-clock me-1"></i>Updated @lastUpdated.ToString("h:mm:ss tt")
                </span>
                <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshAsync" disabled="@refreshing">
                    @if (refreshing)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    else
                    {
                        <i class="bi bi-arrow-clockwise me-1"></i>
                    }
                    Refresh
                </button>
            </div>
        </div>

        <!-- KPI Stat Cards -->
        <div class="row g-3 mb-4">
            <div class="col-xl-2 col-md-4 col-6">
                <div class="card stat-card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="stat-label">Expected Today</p>
                                <h2 class="stat-value text-primary">@stats!.TodayExpected</h2>
                            </div>
                            <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                                <i class="bi bi-calendar-check"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-md-4 col-6">
                <div class="card stat-card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="stat-label">Checked In</p>
                                <h2 class="stat-value text-success">@stats.TodayCheckedIn</h2>
                            </div>
                            <div class="stat-icon bg-success bg-opacity-10 text-success">
                                <i class="bi bi-person-check"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-md-4 col-6">
                <div class="card stat-card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="stat-label">Inside Now</p>
                                <h2 class="stat-value text-warning">@stats.CurrentlyInside</h2>
                            </div>
                            <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                                <i class="bi bi-door-open"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-md-4 col-6">
                <div class="card stat-card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="stat-label">Checked Out</p>
                                <h2 class="stat-value text-secondary">@stats.TodayCheckedOut</h2>
                            </div>
                            <div class="stat-icon bg-secondary bg-opacity-10 text-secondary">
                                <i class="bi bi-box-arrow-right"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-md-4 col-6">
                <div class="card stat-card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="stat-label">This Week</p>
                                <h2 class="stat-value text-info">@stats.WeekTotal</h2>
                            </div>
                            <div class="stat-icon bg-info bg-opacity-10 text-info">
                                <i class="bi bi-calendar-week"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-md-4 col-6">
                <div class="card stat-card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="stat-label">This Month</p>
                                <h2 class="stat-value text-purple">@stats.MonthTotal</h2>
                            </div>
                            <div class="stat-icon bg-purple-subtle text-purple">
                                <i class="bi bi-calendar-month"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 30-day Trend Chart -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-graph-up me-2 text-primary"></i>30-Day Visitor Trend</h6>
                    <small class="text-muted">Daily check-ins over the last 30 days</small>
                </div>
            </div>
            <div class="card-body" style="height: 220px; position: relative;">
                <canvas id="trend-chart"></canvas>
            </div>
        </div>

        <!-- Upcoming Visits + Recent Activity -->
        <div class="row g-3 mb-4">

            <!-- Upcoming Visits Table -->
            <div class="col-xl-8">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
                        <div>
                            <h6 class="mb-0 fw-semibold">
                                <i class="bi bi-clock-history me-2 text-primary"></i>Upcoming Visits
                            </h6>
                            <small class="text-muted">Next 24 hours</small>
                        </div>
                        <a href="@(TenantCtx.RouteBase)/visitors" class="btn btn-sm btn-outline-primary">
                            View All <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                    <div class="card-body p-0">
                        @if (!stats.UpcomingVisits.Any())
                        {
                            <div class="empty-state">
                                <i class="bi bi-calendar-x fs-1 text-muted d-block mb-2"></i>
                                <p class="text-muted mb-0">No upcoming visits in the next 24 hours</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-3">Visitor</th>
                                            <th>Host</th>
                                            <th>Purpose</th>
                                            <th>Scheduled</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var visit in stats.UpcomingVisits)
                                        {
                                            <tr>
                                                <td class="ps-3">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <div class="visitor-avatar">@(visit.Visitor.FullName.Length > 0 ? visit.Visitor.FullName[0].ToString().ToUpper() : "?")</div>
                                                        <div>
                                                            <div class="fw-medium">@visit.Visitor.FullName</div>
                                                            <small class="text-muted">@(visit.Visitor.Company ?? visit.Visitor.Email)</small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    @if (visit.Host != null)
                                                    {
                                                        <span>@visit.Host.FullName</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">—</span>
                                                    }
                                                </td>
                                                <td>
                                                    <span class="badge bg-light text-dark border">@visit.Purpose</span>
                                                </td>
                                                <td>
                                                    <div class="fw-medium">@visit.ScheduledAt.ToLocalTime().ToString("h:mm tt")</div>
                                                    <small class="text-muted">@GetRelativeTime(visit.ScheduledAt)</small>
                                                </td>
                                                <td>@((MarkupString)GetStatusBadge(visit.Status))</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Recent Activity Feed -->
            <div class="col-xl-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="mb-0 fw-semibold">
                            <i class="bi bi-activity me-2 text-success"></i>Recent Activity
                        </h6>
                        <small class="text-muted">Live check-in/out feed</small>
                    </div>
                    <div class="card-body p-0" style="max-height: 420px; overflow-y: auto;">
                        @if (!stats.RecentActivity.Any())
                        {
                            <div class="empty-state">
                                <i class="bi bi-wifi-off fs-1 text-muted d-block mb-2"></i>
                                <p class="text-muted mb-0">No recent activity</p>
                            </div>
                        }
                        else
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var visit in stats.RecentActivity)
                                {
                                    <li class="activity-item px-3 py-2 border-bottom">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="@(visit.Status == VisitStatus.CheckedIn ? "activity-dot bg-success" : "activity-dot bg-secondary")"></div>
                                            <div class="flex-grow-1 min-w-0">
                                                <div class="fw-medium text-truncate">@visit.Visitor.FullName</div>
                                                <small class="text-muted">
                                                    @(visit.Status == VisitStatus.CheckedIn ? "Checked In" : "Checked Out")
                                                    &bull; @GetActivityTime(visit)
                                                    @{
                                                        var gate = visit.Status == VisitStatus.CheckedIn
                                                            ? visit.EntryEntrance
                                                            : (visit.ExitEntrance ?? visit.EntryEntrance);
                                                    }
                                                    @if (gate is not null)
                                                    {
                                                        <span> &bull; <i class="bi bi-door-open"></i> @gate.Name</span>
                                                    }
                                                </small>
                                            </div>
                                            @if (visit.Status == VisitStatus.CheckedIn)
                                            {
                                                <span class="badge bg-success-subtle text-success border-0" style="font-size: 0.7rem;">IN</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary-subtle text-secondary border-0" style="font-size: 0.7rem;">OUT</span>
                                            }
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>

        </div>

        <!-- Today's Breakdown + Quick Actions -->
        <div class="row g-3">

            <!-- Today's Visitor Breakdown -->
            <div class="col-xl-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="mb-0 fw-semibold">
                            <i class="bi bi-bar-chart-steps me-2 text-info"></i>Today's Visitor Breakdown
                        </h6>
                    </div>
                    <div class="card-body p-0">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3" style="width: 30%">Category</th>
                                    <th style="width: 15%" class="text-center">Count</th>
                                    <th>Progress</th>
                                    <th style="width: 10%" class="text-end pe-3">%</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var expected = stats.TodayExpected == 0 ? 1 : stats.TodayExpected;
                                }
                                <tr>
                                    <td class="ps-3">
                                        <span class="d-flex align-items-center gap-2">
                                            <span class="status-dot bg-primary"></span> Scheduled
                                        </span>
                                    </td>
                                    <td class="text-center fw-bold text-primary">@stats.TodayExpected</td>
                                    <td>
                                        <div class="progress" style="height: 10px; border-radius: 6px;">
                                            <div class="progress-bar bg-primary" style="width: 100%;"></div>
                                        </div>
                                    </td>
                                    <td class="text-end pe-3 text-muted small">100%</td>
                                </tr>
                                <tr>
                                    <td class="ps-3">
                                        <span class="d-flex align-items-center gap-2">
                                            <span class="status-dot bg-success"></span> Checked In
                                        </span>
                                    </td>
                                    <td class="text-center fw-bold text-success">@stats.TodayCheckedIn</td>
                                    <td>
                                        @{ var checkedInPct = stats.TodayCheckedIn * 100 / expected; }
                                        <div class="progress" style="height: 10px; border-radius: 6px;">
                                            <div class="progress-bar bg-success" style="width: @checkedInPct%;"></div>
                                        </div>
                                    </td>
                                    <td class="text-end pe-3 text-muted small">@checkedInPct%</td>
                                </tr>
                                <tr>
                                    <td class="ps-3">
                                        <span class="d-flex align-items-center gap-2">
                                            <span class="status-dot bg-warning"></span> Currently Inside
                                        </span>
                                    </td>
                                    <td class="text-center fw-bold text-warning">@stats.CurrentlyInside</td>
                                    <td>
                                        @{ var insidePct = stats.CurrentlyInside * 100 / expected; }
                                        <div class="progress" style="height: 10px; border-radius: 6px;">
                                            <div class="progress-bar bg-warning" style="width: @insidePct%;"></div>
                                        </div>
                                    </td>
                                    <td class="text-end pe-3 text-muted small">@insidePct%</td>
                                </tr>
                                <tr>
                                    <td class="ps-3">
                                        <span class="d-flex align-items-center gap-2">
                                            <span class="status-dot bg-secondary"></span> Checked Out
                                        </span>
                                    </td>
                                    <td class="text-center fw-bold text-secondary">@stats.TodayCheckedOut</td>
                                    <td>
                                        @{ var checkedOutPct = stats.TodayCheckedOut * 100 / expected; }
                                        <div class="progress" style="height: 10px; border-radius: 6px;">
                                            <div class="progress-bar bg-secondary" style="width: @checkedOutPct%;"></div>
                                        </div>
                                    </td>
                                    <td class="text-end pe-3 text-muted small">@checkedOutPct%</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="col-xl-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="mb-0 fw-semibold">
                            <i class="bi bi-lightning me-2 text-warning"></i>Quick Actions
                        </h6>
                    </div>
                    <div class="card-body d-flex flex-column gap-2">
                        <a href="@(TenantCtx.RouteBase)/visitors/checkin" class="btn btn-primary d-flex align-items-center gap-2">
                            <i class="bi bi-person-check-fill fs-5"></i>
                            <span>
                                <strong>Check In Visitor</strong><br>
                                <small class="opacity-75">Walk-in or scheduled</small>
                            </span>
                        </a>
                        <a href="@(TenantCtx.RouteBase)/visitors/preregister" class="btn btn-outline-primary d-flex align-items-center gap-2">
                            <i class="bi bi-person-plus fs-5"></i>
                            <span>
                                <strong>Pre-register Visit</strong><br>
                                <small>Schedule a future visit</small>
                            </span>
                        </a>
                        <a href="@(TenantCtx.RouteBase)/visitors" class="btn btn-outline-secondary d-flex align-items-center gap-2">
                            <i class="bi bi-people fs-5"></i>
                            <span>
                                <strong>Manage Visitors</strong><br>
                                <small>View all visitor records</small>
                            </span>
                        </a>
                        <a href="@(TenantCtx.RouteBase)/reports" class="btn btn-outline-secondary d-flex align-items-center gap-2">
                            <i class="bi bi-file-earmark-bar-graph fs-5"></i>
                            <span>
                                <strong>View Reports</strong><br>
                                <small>Analytics &amp; exports</small>
                            </span>
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = string.Empty;

    private bool loading = true;
    private bool tenantNotFound;
    private bool refreshing;
    private DashboardStats? stats;
    private DateTime lastUpdated;
    private PeriodicTimer? _autoRefreshTimer;
    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        tenantNotFound = false;

        // Resolve auth state first — needed for both the ownership check and the staff redirect
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user      = authState.User;

        // Re-resolve when the context is missing OR the slug changed during soft navigation
        if (!TenantCtx.IsResolved || (!TenantCtx.IsCustomDomain && TenantCtx.TenantSlug != TenantSlug))
        {
            var tenant = await TenantService.ResolveBySlugAsync(TenantSlug);
            if (tenant == null)
            {
                tenantNotFound = true;
                loading = false;
                return;
            }

            // Security: verify the authenticated user belongs to this tenant.
            // SuperAdmin is exempt (cross-tenant by design).
            if (!user.IsInRole(Program.RoleSuperAdmin))
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (userId is not null)
                {
                    var appUser = await UserMgr.FindByIdAsync(userId);
                    if (appUser is null || appUser.TenantId != tenant.Id)
                    {
                        Nav.NavigateTo("/access-denied", replace: true);
                        loading = false;
                        return;
                    }
                }
            }

            TenantCtx.TenantId   = tenant.Id;
            TenantCtx.TenantSlug = tenant.Slug;
            TenantCtx.TenantName = tenant.Name;
            TenantCtx.IsResolved = true;
        }

        // Redirect residents (non-staff) to the resident portal
        bool isStaff = user.IsInRole(Program.RoleAdmin)  || user.IsInRole(Program.RoleManager) ||
                       user.IsInRole(Program.RoleReceptionist) || user.IsInRole(Program.RoleSecurity);
        if (!isStaff)
        {
            Nav.NavigateTo($"{TenantCtx.RouteBase}/resident", replace: true);
            return;
        }

        stats = await DashboardService.GetStatsAsync();
        lastUpdated = DateTime.Now;
        loading = false;
    }

    private bool _chartRendered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _autoRefreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(30));
            _ = Task.Run(async () =>
            {
                try
                {
                    while (await _autoRefreshTimer.WaitForNextTickAsync(_cts.Token))
                    {
                        await InvokeAsync(async () =>
                        {
                            await RefreshAsync();
                            StateHasChanged();
                        });
                    }
                }
                catch (OperationCanceledException) { }
            });
        }

        if (!_chartRendered && stats is not null && stats.DailyTrend.Count > 0)
        {
            _chartRendered = true;
            await RenderChartAsync();
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _autoRefreshTimer?.Dispose();
        _cts.Dispose();
    }

    private async Task RefreshAsync()
    {
        refreshing = true;
        stats = await DashboardService.GetStatsAsync();
        lastUpdated = DateTime.Now;
        refreshing = false;
        await RenderChartAsync();
    }

    private async Task RenderChartAsync()
    {
        if (stats?.DailyTrend is null || stats.DailyTrend.Count == 0) return;
        try
        {
            var labels = stats.DailyTrend.Select(d => d.Date.ToString("MMM d")).ToArray();
            var data   = stats.DailyTrend.Select(d => d.Count).ToArray();
            await JS.InvokeVoidAsync("chartManager.renderTrendChart", "trend-chart", labels, data);
        }
        catch { /* JS not yet loaded */ }
    }

    private string GetRelativeTime(DateTime dt)
    {
        var diff = dt.ToUniversalTime() - DateTime.UtcNow;
        if (diff.TotalMinutes < 0) return "overdue";
        if (diff.TotalMinutes < 60) return $"in {(int)diff.TotalMinutes}m";
        if (diff.TotalHours < 24) return $"in {(int)diff.TotalHours}h";
        return dt.ToLocalTime().ToString("MMM d");
    }

    private string GetActivityTime(Visit visit)
    {
        var dt = visit.Status == VisitStatus.CheckedIn ? visit.CheckedInAt : visit.CheckedOutAt;
        return dt.HasValue ? dt.Value.ToLocalTime().ToString("h:mm tt") : "—";
    }

    private static string GetStatusBadge(VisitStatus status) => status switch
    {
        VisitStatus.Scheduled  => "<span class=\"badge bg-primary\">Scheduled</span>",
        VisitStatus.CheckedIn  => "<span class=\"badge bg-success\">Checked In</span>",
        VisitStatus.CheckedOut => "<span class=\"badge bg-secondary\">Checked Out</span>",
        VisitStatus.Cancelled  => "<span class=\"badge bg-danger\">Cancelled</span>",
        VisitStatus.NoShow     => "<span class=\"badge bg-warning text-dark\">No Show</span>",
        _                      => "<span class=\"badge bg-light text-dark\">Unknown</span>"
    };
}
