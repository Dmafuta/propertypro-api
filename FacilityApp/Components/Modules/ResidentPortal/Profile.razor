@page "/{TenantSlug}/resident/profile"
@page "/resident/profile"
@layout ResidentLayout
@rendermode new InteractiveServerRenderMode(prerender: false)
@attribute [Authorize(Policy = "CanViewOwnHistory")]
@inject UserManager<ApplicationUser> UserManager
@inject IUnitService UnitSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject AuthenticationStateProvider AuthState

<PageTitle>My Profile — @TenantCtx.TenantName</PageTitle>

<div class="mb-4">
    <h4 class="mb-0 fw-bold"><i class="bi bi-person-circle me-2 text-primary"></i>My Profile</h4>
    <small class="text-muted">Manage your account details and view your unit</small>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="row g-4">

        <!-- Unit info (read-only) -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-building me-2 text-primary"></i>My Unit</h6>
                </div>
                <div class="card-body">
                    @if (_units.Count == 0)
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-house-x fs-2 d-block mb-2 opacity-50"></i>
                            <div class="small">No unit assigned to your account.</div>
                            <div class="small mt-1">Contact facility management to link your unit.</div>
                        </div>
                    }
                    else
                    {
                        @foreach (var (unit, linkType) in _units)
                        {
                            <div class="d-flex align-items-start gap-3 @(_units.IndexOf((unit, linkType)) > 0 ? "mt-3 pt-3 border-top" : "")">
                                <div class="rounded-3 bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center"
                                     style="width:44px;height:44px;flex-shrink:0;font-size:1.2rem;">
                                    <i class="bi bi-house-door-fill"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold fs-5">
                                        @(unit.Block is not null ? $"{unit.Block}-{unit.UnitNumber}" : unit.UnitNumber)
                                    </div>
                                    @if (unit.Floor is not null)
                                    {
                                        <div class="small text-muted">Floor @unit.Floor</div>
                                    }
                                    @if (unit.Description is not null)
                                    {
                                        <div class="small text-muted">@unit.Description</div>
                                    }
                                    <span class="badge mt-1 @(linkType == UnitLinkType.Owner ? "bg-warning text-dark" : "bg-primary")">
                                        @(linkType == UnitLinkType.Owner ? "Owner" : "Occupant")
                                    </span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Edit profile -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-pencil me-2 text-primary"></i>Personal Details</h6>
                </div>
                <div class="card-body">
                    @if (_profileSuccess is not null)
                    {
                        <div class="alert alert-success py-2 small mb-3">
                            <i class="bi bi-check-circle me-1"></i>@_profileSuccess
                        </div>
                    }
                    @if (_profileError is not null)
                    {
                        <div class="alert alert-danger py-2 small mb-3">
                            <i class="bi bi-exclamation-triangle me-1"></i>@_profileError
                        </div>
                    }
                    <EditForm Model="_profileForm" OnValidSubmit="SaveProfileAsync">
                        <DataAnnotationsValidator />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Full Name <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_profileForm.FullName" />
                                <ValidationMessage For="() => _profileForm.FullName" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Phone</label>
                                <InputText class="form-control" @bind-Value="_profileForm.Phone" placeholder="+1 555 000 0000" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium small">Email</label>
                                <input class="form-control bg-light" value="@_email" disabled />
                                <small class="text-muted">Email cannot be changed here. Contact facility management.</small>
                            </div>
                        </div>
                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary" disabled="@_profileBusy">
                                @if (_profileBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Save Changes
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>

            <!-- Change password -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-shield-lock me-2 text-primary"></i>Change Password</h6>
                </div>
                <div class="card-body">
                    @if (_pwdSuccess is not null)
                    {
                        <div class="alert alert-success py-2 small mb-3">
                            <i class="bi bi-check-circle me-1"></i>@_pwdSuccess
                        </div>
                    }
                    @if (_pwdError is not null)
                    {
                        <div class="alert alert-danger py-2 small mb-3">
                            <i class="bi bi-exclamation-triangle me-1"></i>@_pwdError
                        </div>
                    }
                    <EditForm Model="_pwdForm" OnValidSubmit="ChangePasswordAsync">
                        <DataAnnotationsValidator />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Current Password <span class="text-danger">*</span></label>
                                <InputText type="password" class="form-control" @bind-Value="_pwdForm.CurrentPassword" />
                                <ValidationMessage For="() => _pwdForm.CurrentPassword" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">New Password <span class="text-danger">*</span></label>
                                <InputText type="password" class="form-control" @bind-Value="_pwdForm.NewPassword" />
                                <ValidationMessage For="() => _pwdForm.NewPassword" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Confirm New Password <span class="text-danger">*</span></label>
                                <InputText type="password" class="form-control" @bind-Value="_pwdForm.ConfirmPassword" />
                                <ValidationMessage For="() => _pwdForm.ConfirmPassword" class="text-danger small" />
                            </div>
                        </div>
                        <div class="mt-3">
                            <button type="submit" class="btn btn-outline-primary" disabled="@_pwdBusy">
                                @if (_pwdBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Update Password
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private bool _loading = true;
    private string _userId = "";
    private string _email = "";

    private List<(Unit Unit, UnitLinkType LinkType)> _units = [];

    // Profile form
    private ProfileForm _profileForm = new();
    private bool _profileBusy;
    private string? _profileSuccess;
    private string? _profileError;

    // Password form
    private PasswordForm _pwdForm = new();
    private bool _pwdBusy;
    private string? _pwdSuccess;
    private string? _pwdError;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        var auth = await AuthState.GetAuthenticationStateAsync();
        _userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        if (!string.IsNullOrEmpty(_userId))
        {
            var user = await UserManager.FindByIdAsync(_userId);
            if (user is not null)
            {
                _email = user.Email ?? "";
                _profileForm.FullName = user.FullName;
                _profileForm.Phone    = user.PhoneNumber ?? "";
            }
            _units = await UnitSvc.GetForUserAsync(_userId);
        }
        _loading = false;
    }

    private async Task SaveProfileAsync()
    {
        _profileBusy    = true;
        _profileSuccess = null;
        _profileError   = null;
        try
        {
            var user = await UserManager.FindByIdAsync(_userId)
                ?? throw new InvalidOperationException("User not found.");

            user.FullName     = _profileForm.FullName!.Trim();
            user.PhoneNumber  = _profileForm.Phone?.Trim();
            user.UserName     = user.Email; // keep username in sync

            var result = await UserManager.UpdateAsync(user);
            if (result.Succeeded)
                _profileSuccess = "Profile updated successfully.";
            else
                _profileError = string.Join(" ", result.Errors.Select(e => e.Description));
        }
        catch (Exception ex) { _profileError = ex.Message; }
        finally { _profileBusy = false; }
    }

    private async Task ChangePasswordAsync()
    {
        _pwdBusy    = true;
        _pwdSuccess = null;
        _pwdError   = null;
        try
        {
            if (_pwdForm.NewPassword != _pwdForm.ConfirmPassword)
            {
                _pwdError = "New passwords do not match.";
                return;
            }

            var user = await UserManager.FindByIdAsync(_userId)
                ?? throw new InvalidOperationException("User not found.");

            var result = await UserManager.ChangePasswordAsync(
                user, _pwdForm.CurrentPassword!, _pwdForm.NewPassword!);

            if (result.Succeeded)
            {
                _pwdSuccess = "Password changed successfully.";
                _pwdForm    = new PasswordForm();
            }
            else
            {
                _pwdError = string.Join(" ", result.Errors.Select(e => e.Description));
            }
        }
        catch (Exception ex) { _pwdError = ex.Message; }
        finally { _pwdBusy = false; }
    }

    private sealed class ProfileForm
    {
        [Required(ErrorMessage = "Name is required.")]
        [MaxLength(100)]
        public string? FullName { get; set; }
        public string? Phone { get; set; }
    }

    private sealed class PasswordForm
    {
        [Required(ErrorMessage = "Current password is required.")]
        public string? CurrentPassword { get; set; }

        [Required(ErrorMessage = "New password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string? NewPassword { get; set; }

        [Required(ErrorMessage = "Please confirm your new password.")]
        public string? ConfirmPassword { get; set; }
    }
}
