greatwallgardens.estate {

    # ── Static files served by ASP.NET Core ──────────────────────────────────
    handle /uploads/* {
        reverse_proxy app:8080
    }
    handle /documents/* {
        reverse_proxy app:8080
    }

    # Health check + dev seed endpoints
    handle /health {
        reverse_proxy app:8080
    }
    handle /dev/* {
        reverse_proxy app:8080
    }

    # ── Next.js API calls: /backend/* → ASP.NET Core (strips prefix) ─────────
    handle_path /backend/* {
        reverse_proxy app:8080 {
            header_up Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_down -Server
        }
    }

    # ── Next.js SuperAdmin frontend ───────────────────────────────────────────
    handle /superadmin/* {
        reverse_proxy web:3000 {
            header_up Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_down -Server
        }
    }
    handle /platform/* {
        reverse_proxy web:3000 {
            header_up Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_down -Server
        }
    }
    handle /_next/* {
        reverse_proxy web:3000 {
            header_up Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_down -Server
        }
    }
    handle /api/auth/* {
        reverse_proxy web:3000 {
            header_up Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_down -Server
        }
    }

    # ── Next.js: all tenant pages (catch-all) ────────────────────────────────
    handle {
        reverse_proxy web:3000 {
            header_up Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_down -Server
        }
    }

    encode gzip
    header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    header -Server
}
