greatwallgardens.estate {

    # ── ASP.NET Core REST API ─────────────────────────────────────────────────
    # Requests to /backend/* are stripped of the prefix and forwarded to
    # the app container at /api/* (e.g. /backend/api/auth/login → /api/auth/login).
    handle_path /backend/* {
        reverse_proxy app:8080 {
            header_up Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_down -Server
        }
    }

    # Static files served by ASP.NET Core (visitor photos, documents)
    handle /uploads/* {
        reverse_proxy app:8080
    }
    handle /documents/* {
        reverse_proxy app:8080
    }

    # Health check endpoint
    handle /health {
        reverse_proxy app:8080
    }

    # Dev seed endpoints (only active in Development environment)
    handle /dev/* {
        reverse_proxy app:8080
    }

    # ── Next.js frontend (catch-all) ──────────────────────────────────────────
    handle {
        reverse_proxy web:3000 {
            header_up Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_down -Server
        }
    }

    encode gzip
    header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    header -Server
}
