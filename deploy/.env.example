# ── FacilityApp — Environment Variables ──────────────────────────────────────
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#   nano .env
#
# IMPORTANT: Never commit .env to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Strong random password for PostgreSQL (no special shell characters)
DB_PASSWORD=change_me_use_a_strong_random_password

# ── SMTP / Email ──────────────────────────────────────────────────────────────
# Required for password-reset emails. Leave blank to disable email (users
# who forget their password will need manual intervention).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_SSL=false
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_ADDRESS=noreply@example.com
SMTP_FROM_NAME=PropertyPro

# ── Africa's Talking (SMS) ─────────────────────────────────────────────────────
# Register at africastalking.com. Use Sandbox=true for testing.
AT_USERNAME=your_at_username
AT_API_KEY=your_at_api_key
AT_SENDER_ID=
AT_SANDBOX=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 64
JWT_SECRET=change_me_use_a_long_random_secret
JWT_ISSUER=FacilityApp
JWT_AUDIENCE=FacilityApp
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=30
